@{
    ViewBag.Title = "Dashboard SafeDorm AI";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .summary-card {
        border-radius: 16px;
        padding: 20px;
        background: #fff;
        border: 1px solid #e9ecef;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        height: 100%;
    }

    .summary-label {
        font-size: 0.85rem;
        color: #6c757d;
        text-transform: uppercase;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .summary-value {
        font-size: 2rem;
        font-weight: 800;
        color: #212529;
        line-height: 1.2;
    }

    .room-pill {
        cursor: pointer;
        transition: all 0.25s ease;
        border-radius: 14px;
        padding: 14px 16px;
        min-width: 140px;
        border: 2px solid transparent;
        color: #fff;
    }

        .room-pill:hover {
            transform: translateY(-2px);
        }

        .room-pill.active {
            border-color: #212529 !important;
            box-shadow: 0 6px 16px rgba(0,0,0,0.18);
        }

    .temp-normal {
        background: linear-gradient(135deg, #198754, #20c997);
    }

    .temp-warning {
        background: linear-gradient(135deg, #ffc107, #fd7e14);
        color: #212529 !important;
    }

    .temp-danger {
        background: linear-gradient(135deg, #dc3545, #b02a37);
    }

    .panel-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e9ecef;
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
    }

    .ai-card-dark {
        background: linear-gradient(180deg, #1f2329, #15181c);
        color: #fff;
        border-radius: 16px;
        min-height: 100%;
    }

    .empty-box {
        border: 2px dashed #dee2e6;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        color: #6c757d;
        background: #fafafa;
    }
</style>

<div class="container-fluid p-0">
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="summary-card">
                <div class="summary-label">Tổng Phòng Có Dữ Liệu</div>
                <div id="totalRooms" class="summary-value">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="summary-card">
                <div class="summary-label">Phòng Đang Cảnh Báo</div>
                <div id="alertRoomsCount" class="summary-value text-danger">0</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="summary-card">
                <div class="summary-label">Phòng Nóng Nhất</div>
                <div id="hottestRoom" class="summary-value">--</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="summary-card">
                <div class="summary-label">Nhiệt Độ Cao Nhất</div>
                <div id="hottestTemp" class="summary-value text-danger">0°C</div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12">
            <div class="panel-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="fa-solid fa-fire text-danger me-2"></i>
                        Các Phòng Có Nhiệt Độ Cao
                    </h5>
                    <span class="badge bg-light text-dark border">Chỉ hiển thị phòng >= 38°C</span>
                </div>

                <div id="hotRoomList" class="d-flex flex-wrap gap-3">
                    <div class="text-muted">Đang tải dữ liệu...</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="panel-card p-4 mb-4">
                <h5 class="fw-bold text-danger mb-3">
                    <i class="fa-solid fa-chart-column me-2"></i>
                    Biểu Đồ Các Phòng Nhiệt Độ Cao Hiện Tại
                </h5>
                <div style="height: 320px;">
                    <canvas id="hotRoomsChart"></canvas>
                </div>
            </div>

            <div class="panel-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 id="historyTitle" class="fw-bold text-primary mb-0">
                        <i class="fa-solid fa-chart-line me-2"></i>
                        Lịch Sử Nhiệt Độ
                    </h5>
                    <button class="btn btn-outline-primary btn-sm rounded-pill" onclick="loadBaoCaoAIData(currentRoomId)">
                        <i class="fa-solid fa-rotate-right me-1"></i>Làm mới
                    </button>
                </div>
                <div style="height: 320px;">
                    <canvas id="roomHistoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel-card p-4 mb-4">
                <h5 class="fw-bold text-warning mb-3">
                    <i class="fa-solid fa-building-circle-exclamation me-2"></i>
                    Cảnh Báo Theo Dãy
                </h5>
                <div style="height: 320px;">
                    <canvas id="blockChart"></canvas>
                </div>
            </div>

            <div class="ai-card-dark p-4 shadow">
                <h6 class="fw-bold mb-3 text-warning text-uppercase">
                    <i class="fa-solid fa-microchip me-2"></i>SafeGuard AI Core
                </h6>
                <hr class="border-secondary" />
                <div id="aiSummaryBox" style="line-height:1.9; font-size:0.96rem;">
                    Đang phân tích dữ liệu cảm biến...
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let currentRoomId = null;
        let hotRoomsChart = null;
        let roomHistoryChart = null;
        let blockChart = null;

        function getTempClass(temp) {
            if (temp >= 45) return "temp-danger";
            if (temp >= 38) return "temp-warning";
            return "temp-normal";
        }

        function loadBaoCaoAIData(roomId = null) {
            let url = '@Url.Action("GetBaoCaoAIData", "Admin")';
            if (roomId) {
                url += '?roomId=' + encodeURIComponent(roomId);
            }

            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (!data.success) {
                        document.getElementById("aiSummaryBox").innerHTML =
                            `<span class="text-warning">Lỗi tải dữ liệu: ${data.message || 'Không xác định'}</span>`;
                        return;
                    }

                    document.getElementById("totalRooms").innerText = data.totalRooms;
                    document.getElementById("alertRoomsCount").innerText = data.alertRoomsCount;
                    document.getElementById("hottestRoom").innerText = data.hottestRoom || "--";
                    document.getElementById("hottestTemp").innerText = `${data.hottestTemp || 0}°C`;
                    document.getElementById("aiSummaryBox").innerHTML = data.aiSummary || "Chưa có phân tích.";

                    currentRoomId = data.selectedRoom;

                    document.getElementById("historyTitle").innerHTML =
                        `<i class="fa-solid fa-chart-line me-2"></i>Lịch Sử Nhiệt Độ ${data.selectedRoom || ""}`;

                    const hotRoomList = document.getElementById("hotRoomList");
                    hotRoomList.innerHTML = "";

                    if (!data.hotRooms || data.hotRooms.length === 0) {
                        hotRoomList.innerHTML = `
                            <div class="empty-box w-100">
                                <i class="fa-solid fa-circle-check text-success me-2"></i>
                                Hiện chưa có phòng nào vượt ngưỡng 38°C.
                            </div>
                        `;
                    } else {
                        data.hotRooms.forEach(room => {
                            const div = document.createElement("div");
                            div.className = `room-pill ${getTempClass(room.temperature)} ${room.roomId === currentRoomId ? 'active' : ''}`;
                            div.innerHTML = `
                                <div class="small opacity-75">Dãy ${room.blockName}</div>
                                <div class="fs-4 fw-bold">${room.roomId}</div>
                                <div class="small fw-semibold">${room.temperature}°C</div>
                                <div class="small opacity-75">${room.time}</div>
                            `;
                            div.onclick = () => loadBaoCaoAIData(room.roomId);
                            hotRoomList.appendChild(div);
                        });
                    }

                    const hotLabels = (data.hotRooms || []).map(x => x.roomId);
                    const hotTemps = (data.hotRooms || []).map(x => x.temperature);

                    if (hotRoomsChart) hotRoomsChart.destroy();
                    hotRoomsChart = new Chart(document.getElementById("hotRoomsChart"), {
                        type: 'bar',
                        data: {
                            labels: hotLabels,
                            datasets: [{
                                label: 'Nhiệt độ (°C)',
                                data: hotTemps,
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true
                                }
                            }
                        }
                    });

                    if (roomHistoryChart) roomHistoryChart.destroy();
                    roomHistoryChart = new Chart(document.getElementById("roomHistoryChart"), {
                        type: 'line',
                        data: {
                            labels: data.selectedRoomLabels || [],
                            datasets: [{
                                label: 'Nhiệt độ (°C)',
                                data: data.selectedRoomTemps || [],
                                fill: true,
                                tension: 0.35,
                                borderWidth: 3,
                                pointRadius: 4
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                y: {
                                    beginAtZero: false
                                }
                            }
                        }
                    });

                    const blockLabels = (data.blockStats || []).map(x => x.BlockName);
                    const blockCounts = (data.blockStats || []).map(x => x.AlertCount);

                    if (blockChart) blockChart.destroy();
                    blockChart = new Chart(document.getElementById("blockChart"), {
                        type: 'bar',
                        data: {
                            labels: blockLabels,
                            datasets: [{
                                label: 'Số phòng cảnh báo',
                                data: blockCounts,
                                borderWidth: 1
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            indexAxis: 'y',
                            plugins: {
                                legend: { display: false }
                            },
                            scales: {
                                x: {
                                    beginAtZero: true,
                                    ticks: {
                                        precision: 0
                                    }
                                }
                            }
                        }
                    });
                })
                .catch(err => {
                    console.error(err);
                    document.getElementById("aiSummaryBox").innerHTML =
                        `<span class="text-warning">Không thể kết nối dữ liệu báo cáo AI.</span>`;
                });
        }

        document.addEventListener("DOMContentLoaded", function () {
            loadBaoCaoAIData();
        });
    </script>
}