@{
    ViewBag.Title = "Tổng Quan Hệ Thống";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* HIỆU ỨNG CHUYỂN ĐỘNG */
    .anim-fade-up {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* GIAO DIỆN "THỀM TRẮNG" CỰC ĐẸP */
    .custom-card {
        background-color: #ffffff;
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.3s ease;
    }

        .custom-card:hover {
            box-shadow: 0 8px 25px rgba(0,0,0,0.08);
            transform: translateY(-2px);
        }

    .card-title-custom {
        font-weight: 700;
        color: #495057;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* CSS TRẠNG THÁI */
    .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }

    .bg-green {
        background-color: #28a745;
    }

    .bg-red {
        background-color: #dc3545;
    }

    .pulse {
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(220,53,69, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(220,53,69, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(220,53,69, 0);
        }
    }
</style>

<div class="container-fluid p-0">
    <div class="row g-4 mb-4">
        <div class="col-md-7 anim-fade-up">
            <div class="custom-card p-4 h-100">
                <h6 class="card-title-custom">Tóm Tắt Hệ Thống</h6>
                <div class="row mt-3">
                    <div class="col-6 mb-2">
                        <span class="text-muted small">Tổng Số Phòng:</span>
                        <strong class="fs-5 ms-2">@(ViewBag.TotalRooms ?? 0)</strong>
                    </div>
                    <div class="col-6 mb-2">
                        <span class="text-muted small">Cảnh Báo Hiện Tại:</span>
                        <strong id="summary-alerts" class="fs-5 ms-2 @(ViewBag.CurrentAlerts > 0 ? "text-danger" : "text-success")">
                            @(ViewBag.CurrentAlerts ?? 0)
                        </strong>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Đang Hoạt Động:</span>
                        <strong class="fs-5 ms-2">@(ViewBag.ActiveRooms ?? 0)</strong>
                    </div>
                    <div class="col-6">
                        <span class="text-muted small">Thiết Bị Online:</span>
                        <strong id="summary-online" class="fs-5 ms-2 @(ViewBag.OnlineDevices == ViewBag.TotalRooms && ViewBag.TotalRooms > 0 ? "text-success" : "text-warning")">
                            @(ViewBag.OnlineDevices ?? 0)/@(ViewBag.TotalRooms ?? 0)
                        </strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5 anim-fade-up delay-1">
            <div class="custom-card p-4 h-100">
                <h6 class="card-title-custom">Trạng Thái Gần Đây</h6>
                <ul class="list-unstyled mb-0 mt-3">
                    @{ var recentActs = ViewBag.RecentActivities as List<SafeGuard.Controllers.ViewModels.RecentActivityVM>; }
                    @if (recentActs != null && recentActs.Count > 0)
                    {
                        foreach (var activity in recentActs)
                        {
                            <li class="mb-3 d-flex align-items-center">
                                <span class="status-dot bg-green me-3"></span>
                                <span class="text-muted small">
                                    <strong>@activity.Name</strong> đã tham gia <strong>Phòng @activity.Room</strong>
                                    <span style="font-size: 0.85em; opacity: 0.8;">(@activity.Time)</span>
                                </span>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-muted small d-flex align-items-center">
                            <i class="fa-solid fa-clock-rotate-left me-2"></i> Chưa có dữ liệu mới.
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-8 anim-fade-up delay-2">
            <div class="custom-card p-4 h-100">
                <h6 class="card-title-custom text-primary mb-3">Quản Lý Cảm Biến Theo Phòng</h6>
                <div class="table-responsive">
                    <table class="table table-borderless table-hover align-middle">
                        <thead style="background-color: #f8f9fa;">
                            <tr class="small text-muted text-uppercase">
                                <th>Phòng</th>
                                <th>Trạng Thái</th>
                                <th>Nhiệt Độ</th>
                                <th>Cập Nhật</th>
                            </tr>
                        </thead>
                        <tbody id="alert-tbody">
                            @{ var sensorList = ViewBag.SensorList as List<SafeGuard.Controllers.ViewModels.SensorDataVM>; }
                            @if (sensorList != null && sensorList.Count > 0)
                            {
                                foreach (var sensor in sensorList)
                                {
                                    bool isAlert = sensor.Temp >= 38;
                                    <tr>
                                        <td class="fw-bold @(isAlert ? "text-danger" : "")">@sensor.RoomId</td>
                                        <td><span class="status-dot @(isAlert ? "bg-red pulse" : "bg-green")"></span></td>
                                        <td class="@(isAlert ? "text-danger fw-bold" : "")">@sensor.Temp°C</td>
                                        <td class="small text-muted">@sensor.Time</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4 anim-fade-up delay-2">
            <div class="custom-card p-4 h-100">
                <h6 class="card-title-custom">Tạo Mã Kích Hoạt (Mã Mời)</h6>
                <form method="post" action="@Url.Action("TaoMaMoi", "Admin")">

                    <select name="selectedRoom" class="form-select mb-3 mt-3 shadow-sm" required>
                        <option value="" selected disabled>-- Chọn Phòng --</option>
                        @if (ViewBag.RealRoomsList != null)
                        {
                            var realRooms = ViewBag.RealRoomsList as List<SafeGuard.Models.RoomDisplayViewModel>;
                            foreach (var group in realRooms.GroupBy(r => r.BlockName))
                            {
                                <optgroup label="Dãy @group.Key">
                                    @foreach (var room in group)
                                    {
                                        <option value="@room.BlockName-@room.RoomId">Phòng @room.BlockName-@room.RoomId</option>
                                    }
                                </optgroup>
                            }
                        }
                        else if (ViewBag.Blocks != null)
                        {
                            foreach (var bId in ViewBag.Blocks as List<string>)
                            {
                                <optgroup label="Dãy @bId">
                                    @for (int i = 1; i <= 6; i++)
                                    {
                                        var room = $"{bId}-10{i}";
                                        <option value="@room">Phòng @room</option>
                                    }
                                </optgroup>
                            }
                        }
                    </select>

                    <input type="number" name="expireHours" class="form-control mb-3" value="24" title="Thời hạn mã (Giờ)">
                    <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">TẠO MÃ</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-5 anim-fade-up delay-3">
            <div class="custom-card p-4 h-100">
                <h6 class="card-title-custom mb-0">Phân Tích AI Tổng Quan</h6>
                <div class="mt-3" style="height: 180px;">
                    <canvas id="aiChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-3 anim-fade-up delay-3">
            <div class="custom-card p-3 h-100 d-flex align-items-center justify-content-center">
                <img src="~/Content/images/PiggyShy.png" alt="Bản quyền" class="img-fluid" style="max-height: 180px; object-fit: contain; transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'">
            </div>
        </div>

        <div class="col-md-4 anim-fade-up delay-3">
            <div class="custom-card p-4 text-center h-100 d-flex flex-column justify-content-center">
                <h6 class="card-title-custom">Thông Tin Hệ Thống</h6>
                <i class="fa-brands fa-aws fs-2 text-warning my-2"></i>
                <p class="text-muted small mb-0">Powered by AWS Serverless</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Hàm cập nhật Real-time (Tự động chạy ngầm)
        function updateDashboard() {
            $.get('@Url.Action("GetRealTimeSensorData", "Admin")', function (data) {
                if (data) {
                    let html = '';
                    let alertCount = 0;
                    data.forEach(sensor => {
                        if (sensor.IsAlert) alertCount++;
                        html += `<tr>
                            <td class="fw-bold ${sensor.IsAlert ? 'text-danger' : ''}">${sensor.RoomId}</td>
                            <td><span class="status-dot ${sensor.IsAlert ? 'bg-red pulse' : 'bg-green'}"></span></td>
                            <td class="${sensor.IsAlert ? 'text-danger fw-bold' : ''}">${sensor.Temp}°C</td>
                            <td class="small text-muted">${sensor.Time}</td>
                        </tr>`;
                    });
                    $('#alert-tbody').html(html);
                    $('#summary-online').text(data.length + '/' + @(ViewBag.TotalRooms ?? 0));
                    $('#summary-alerts').text(alertCount).toggleClass('text-danger', alertCount > 0).toggleClass('text-success', alertCount === 0);
                }
            });
        }

        $(document).ready(function() {
            setInterval(updateDashboard, 2000); // Tự cập nhật mỗi 5 giây
        });

        // Vẽ biểu đồ AI
        const ctx = document.getElementById('aiChart').getContext('2d');
        const gradient = ctx.createLinearGradient(0, 0, 0, 150);
        gradient.addColorStop(0, 'rgba(13, 110, 253, 0.2)');
        gradient.addColorStop(1, 'rgba(13, 110, 253, 0)');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['0h', '4h', '8h', '12h', '16h', '20h', '24h'],
                datasets: [{
                    data: [25, 23, 28, 32, 30, 27, 24],
                    borderColor: '#0d6efd',
                    backgroundColor: gradient,
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4,
                    pointRadius: 3
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { min: 20, max: 40 }, x: { grid: { display: false } } }
            }
        });
    </script>
}