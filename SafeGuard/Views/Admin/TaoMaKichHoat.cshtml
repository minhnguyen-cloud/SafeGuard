@{
    ViewBag.Title = "Tạo Mã Kích Hoạt";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid p-0">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-4 anim-fade-up">
            <div class="custom-card p-4">
                <h6 class="card-title-custom text-primary mb-4"><i class="fa-solid fa-key me-2"></i>Tạo Mã Mới</h6>

                <form method="post" action="@Url.Action("TaoMaMoi", "Admin")">
                    <div class="mb-3">
                        <label class="form-label text-muted small fw-bold">Chọn Phòng Cần Liên Kết</label>

                        <select name="selectedRoom" class="form-select" required>
                            <option value="" selected disabled>-- Chọn Phòng Cụ Thể --</option>
                            @if (ViewBag.Blocks != null)
                            {
                                foreach (var block in ViewBag.Blocks)
                                {
                                    var bId = block["BlockId"].AsString();
                                    var bName = block["BlockName"].AsString();
                                    <optgroup label="@bName">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            var room = $"{bId}-10{i}";
                                            <option value="@room">Phòng @room</option>
                                        }
                                    </optgroup>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label text-muted small fw-bold">Thời hạn mã (Giờ)</label>
                        <input type="number" name="expireHours" class="form-control" value="24" min="1" max="72">
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">PHÁT SINH MÃ</button>
                </form>
            </div>
        </div>

        <div class="col-md-8 anim-fade-up delay-1">
            <div class="custom-card p-4 h-100">
                <h6 class="card-title-custom mb-4">Danh sách mã đang kích hoạt</h6>
                <div class="table-responsive">
                    <table class="table table-borderless table-hover align-middle">
                        <thead class="border-bottom">
                            <tr class="text-muted small">
                                <th>Phòng</th>
                                <th>Mã Kích Hoạt</th>
                                <th>Thời gian tạo</th>
                                <th>Trạng Thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.InviteList != null)
                            {
                                foreach (var item in ViewBag.InviteList)
                                {
                                    var isUsed = item.ContainsKey("IsUsed") && item["IsUsed"].AsBoolean();
                                    var createdAt = item.ContainsKey("CreatedAt") ? DateTime.Parse(item["CreatedAt"].AsString()) : DateTime.Now;
                                    var roomId = item.ContainsKey("RoomId") ? item["RoomId"].AsString() : "N/A";
                                    var inviteCode = item.ContainsKey("InviteCode") ? item["InviteCode"].AsString() : "N/A";

                                    <tr>
                                        <td class="fw-bold">Phòng @roomId</td>
                                        <td>
                                            <h5 class="mb-0 fw-bold @(isUsed ? "text-muted text-decoration-line-through" : "text-primary")" style="letter-spacing: 2px;">
                                                @inviteCode
                                            </h5>
                                        </td>
                                        <td class="text-muted small">@createdAt.ToString("dd/MM/yyyy - HH:mm")</td>
                                        <td>
                                            @if (isUsed)
                                            {
                                                <span class="badge bg-success">Đã sử dụng</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">Chờ nhập</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>