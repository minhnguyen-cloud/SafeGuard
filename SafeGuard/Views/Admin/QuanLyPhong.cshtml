@{
    ViewBag.Title = "Quản Lý Phòng";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid p-0">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close close" data-dismiss="alert" data-bs-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close close" data-dismiss="alert" data-bs-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="custom-card p-4 anim-fade-up">
        <div class="row align-items-center mb-4">
            <div class="col-md-4">
                <div class="input-group shadow-sm rounded">
                    <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                    <input type="text" id="txtSearch" class="form-control border-start-0" placeholder="Tìm tên phòng hoặc người quản lý...">
                </div>
            </div>
            <div class="col-md-3">
                <select id="ddlBlock" class="form-select border-0 shadow-sm">
                    <option value="">Tất cả dãy trọ</option>
                    @if (ViewBag.Blocks != null)
                    {
                        foreach (var block in ViewBag.Blocks)
                        {
                            <option value="@block["BlockId"].AsString()">Dãy @block["BlockId"].AsString()</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-5 text-end">
                <button type="button" class="btn btn-primary fw-bold px-4 shadow-sm" onclick="forceOpenModal('addRoomModal')">
                    <i class="fa-solid fa-plus me-2"></i>Thêm Phòng
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table id="roomTable" class="table table-hover align-middle border-top">
                <thead class="table-light">
                    <tr class="text-muted small text-uppercase">
                        <th>Tên Phòng</th>
                        <th>Khu Vực</th>
                        <th>Chủ Trọ (Admin)</th>
                        <th>ID Phòng</th>
                        <th>Trạng Thái</th>
                        <th class="text-center">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.Rooms != null)
                    {
                        foreach (SafeGuard.Models.RoomDisplayViewModel room in (IEnumerable<SafeGuard.Models.RoomDisplayViewModel>)ViewBag.Rooms)
                        {
                            <tr class="room-row">
                                <td class="fw-bold">@room.RoomName</td>
                                <td class="block-column">@room.BlockName</td>
                                <td><span class="text-primary small">@room.OwnerEmail</span></td>
                                <td><code class="text-secondary small">ID-@room.RoomId</code></td>
                                <td>
                                    <span class="badge rounded-pill @(room.IsOnline ? "bg-success" : "bg-secondary") bg-opacity-10 @(room.IsOnline ? "text-success" : "text-muted") border">
                                        <i class="fa-solid @(room.IsOnline ? "fa-circle-check" : "fa-circle-minus") me-1 small"></i>
                                        @(room.IsOnline ? "Online" : "Offline")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-outline-primary border-0 me-1 view-members-btn" data-room-id="@room.BlockName-@room.RoomId" title="Xem người thuê">
                                        <i class="fa-solid fa-users-viewfinder"></i>
                                    </button>

                                    <form action="@Url.Action("XoaPhong", "Admin")" method="post" style="display:inline;" onsubmit="return confirm('Xóa phòng này?')">
                                        <input type="hidden" name="blockId" value="@room.BlockName" />
                                        <input type="hidden" name="roomId" value="@room.RoomId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger border-0"><i class="fa-solid fa-trash-can"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addRoomModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0">
            <div class="modal-header">
                <h5 class="modal-title fw-bold">Thêm Phòng Mới</h5>
                <button type="button" class="btn-close close" data-dismiss="modal" data-bs-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form action="@Url.Action("ThemPhongMoi", "Admin")" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Chọn Dãy Trọ</label>
                        <select name="blockId" class="form-select" required>
                            @if (ViewBag.Blocks != null)
                            {
                                foreach (var block in ViewBag.Blocks)
                                {
                                    <option value="@block["BlockId"].AsString()">@block["BlockName"].AsString()</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Số Thứ Tự Phòng (VD: 101, 102)</label>
                        <input type="number" name="roomNumber" class="form-control" required placeholder="101">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-dismiss="modal" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-bold">Lưu Phòng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="roomMembersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold text-dark">
                    <i class="fa-solid fa-house-user text-primary me-2"></i>Thành viên <span id="modalRoomName" class="text-primary"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div id="membersLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status"></div>
                    <p class="text-muted mt-2 small">Đang tải dữ liệu từ máy chủ AWS...</p>
                </div>

                <div id="membersContent" style="display: none;">
                    <ul class="list-group list-group-flush" id="membersList">
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- HÀM ÉP MỞ MODAL BẤT CHẤP PHIÊN BẢN (Dành cho nút Thêm Phòng) ---
        function forceOpenModal(modalId) {
            var modalEl = document.getElementById(modalId);
            if (!modalEl) return;

            if (typeof jQuery !== 'undefined' && typeof jQuery.fn.modal !== 'undefined') {
                $('#' + modalId).modal('show');
                return;
            }

            if (typeof bootstrap !== 'undefined') {
                var bsModal = bootstrap.Modal.getInstance(modalEl);
                if (!bsModal) {
                    bsModal = new bootstrap.Modal(modalEl);
                }
                bsModal.show();
                return;
            }

            alert("Thiếu thư viện Bootstrap Javascript!");
        }

        // --- HÀM LỌC TÌM KIẾM ---
        document.addEventListener("DOMContentLoaded", function () {
            const txtSearch = document.getElementById("txtSearch");
            const ddlBlock = document.getElementById("ddlBlock");
            const tableRows = document.querySelectorAll("#roomTable tbody tr");

            function applyFilters() {
                const searchText = txtSearch.value.toLowerCase().trim();
                const selectedValue = ddlBlock.value.toLowerCase().trim();

                tableRows.forEach(row => {
                    const rowText = row.innerText.toLowerCase();
                    const blockColumn = row.querySelector(".block-column");
                    const blockText = blockColumn ? blockColumn.innerText.toLowerCase().trim() : "";

                    const matchesSearch = rowText.includes(searchText);
                    const matchesBlock = (selectedValue === "" || blockText === selectedValue);

                    if (matchesSearch && matchesBlock) {
                        row.style.display = "";
                    } else {
                        row.style.display = "none";
                    }
                });
            }

            if (ddlBlock) ddlBlock.addEventListener("change", applyFilters);
            if (txtSearch) txtSearch.addEventListener("input", applyFilters);
        });

        // --- AJAX XỬ LÝ NÚT XEM THÀNH VIÊN ---
        $(document).ready(function () {
            $('.view-members-btn').on('click', function (e) {
                e.preventDefault();

                var roomId = $(this).data('room-id');

                // Cập nhật giao diện chờ
                $('#modalRoomName').text('Phòng ' + roomId);
                $('#membersContent').hide();
                $('#membersLoading').show();
                $('#membersList').empty();

                // Bật Modal
                forceOpenModal('roomMembersModal');

                // Gọi API
                $.get('@Url.Action("GetRoomMembers", "Admin")', { roomId: roomId }, function (res) {
                    $('#membersLoading').hide();
                    $('#membersContent').show();

                    if (res.success && res.data && res.data.length > 0) {
                        let html = '';
                        res.data.forEach(user => {
                            // Tạo avatar 2 chữ cái
                            let names = user.FullName.split(' ');
                            let initials = names.length >= 2
                                ? (names[0].charAt(0) + names[names.length - 1].charAt(0)).toUpperCase()
                                : user.FullName.substring(0, 2).toUpperCase();

                            html += `
                                <li class="list-group-item px-0 py-3 border-bottom d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center fw-bold me-3 flex-shrink-0" style="width: 45px; height: 45px; border: 2px solid #0d6efd;">
                                        ${initials}
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold text-dark">${user.FullName}</h6>
                                        <small class="text-muted"><i class="fa-regular fa-envelope me-1"></i>${user.Email}</small>
                                    </div>
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill ms-auto px-3 py-2 border border-success">Đang thuê</span>
                                </li>
                            `;
                        });
                        $('#membersList').html(html);
                    } else {
                        $('#membersList').html(`
                            <div class="text-center py-4">
                                <i class="fa-solid fa-user-xmark text-muted opacity-25" style="font-size: 3rem;"></i>
                                <p class="text-muted mt-3 mb-0">Phòng này hiện chưa có người thuê.</p>
                            </div>
                        `);
                    }
                }).fail(function () {
                    $('#membersLoading').hide();
                    $('#membersContent').show();
                    $('#membersList').html('<div class="text-center text-danger py-3"><i class="fa-solid fa-triangle-exclamation me-2"></i> Lỗi kết nối đến máy chủ.</div>');
                });
            });
        });
    </script>
}

<style>
    .badge {
        font-weight: 600;
        padding: 0.5em 1em;
    }

    .bg-opacity-10 {
        --bs-bg-opacity: 0.1;
    }

    .modal-content {
        border-radius: 15px;
    }

    .custom-card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        background: #fff;
    }
</style>