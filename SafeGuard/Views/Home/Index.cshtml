                    <p class="text-muted mb-3">Leader & Fullstack Developer</p>
                    <div class="social-links">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-github"></i></a>
                        <a href="#"><i class="fa-solid fa-envelope"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 text-center">
                <div class="team-card p-4">
                    <div class="team-img-box mb-4 mx-auto">
                        <img src="~/Content/images/TV2.jpg" alt="Ngọc Minh" class="img-fluid rounded-circle shadow">
                    </div>
                    <h4 class="fw-bold">Thành Viên 2</h4>
                    <p class="text-muted mb-3">IoT & AWS</p>
                    <div class="social-links">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-github"></i></a>
                        <a href="#"><i class="fa-solid fa-envelope"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-md-4 text-center">
                <div class="team-card p-4">
                    <div class="team-img-box mb-4 mx-auto">
                        <img src="~/Content/images/TV3.jpg" alt="Đắc Tri" class="img-fluid rounded-circle shadow">
                    </div>
                    <h4 class="fw-bold">Đắc Tri</h4>
                    <p class="text-muted mb-3">AI & Backend</p>
                    <div class="social-links">
                        <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                        <a href="#"><i class="fa-brands fa-github"></i></a>
                        <a href="#"><i class="fa-solid fa-envelope"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light border-top border-bottom overflow-hidden">
    <div class="container-fluid text-center">
        <h5 class="text-muted mb-4 fw-bold text-uppercase tracking-wider">Được tin dùng bởi các đơn vị</h5>

        <div class="marquee-wrapper">
            <div class="marquee-track gap-5 partner-logos">
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-building-columns"></i> ĐH Nguyễn Tất Thành</h3>
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-house-chimney"></i> Ký Túc Xá Khu B</h3>
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-shield-cat"></i> SmartHome VN</h3>
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-fire-extinguisher"></i> PCCC TP.HCM</h3>

                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-building-columns"></i> ĐH Nguyễn Tất Thành</h3>
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-house-chimney"></i> Ký Túc Xá Khu B</h3>
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-shield-cat"></i> SmartHome VN</h3>
                <h3 class="text-secondary fw-bold m-0"><i class="fa-solid fa-fire-extinguisher"></i> PCCC TP.HCM</h3>
            </div>
        </div>
    </div>
</section>

<section class="cta-section py-5 position-relative">
    <div class="container text-center text-white py-5 position-relative" style="z-index: 2;">
        <h2 class="display-4 fw-bold mb-3">Chủ động hôm nay – tránh hối tiếc ngày mai</h2>
        <p class="fs-4 mb-5">Đầu tư cho sự an toàn của gia đình và sinh viên ngay hôm nay.</p>
        <a href="@Url.Action("Contact", "Home")"
           class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-lg pulse-button">
            <i class="fa-solid fa-phone-volume me-2"></i> Đăng Ký Ngay
        </a>
    </div>
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-75"></div>
</section>

<style>
    /* Hiệu ứng Box Tính năng */
    .feature-card {
        transition: all 0.4s ease;
    }

        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
            background-color: #fff !important;
        }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.4s ease;
    }

    .feature-card:hover .icon-wrapper {
        transform: scale(1.15) rotate(10deg);
    }

    /* Hiệu ứng Bảng so sánh */
    .compare-card {
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .compare-list li {
        padding: 15px 0;
        border-bottom: 1px dashed #e0e0e0;
        font-size: 1.1rem;
    }

        .compare-list li:last-child {
            border-bottom: none;
        }

    .traditional-card:hover {
        transform: scale(1.02);
    }

    .safeguard-card {
        border: 2px solid var(--accent-orange);
        transform: scale(1.03);
        z-index: 2;
    }

        .safeguard-card:hover {
            transform: scale(1.06);
            box-shadow: 0 25px 50px rgba(255, 159, 28, 0.2) !important;
        }

    /* Hiệu ứng Đội ngũ */
    .team-card {
        background: transparent;
        transition: all 0.3s ease;
    }

    .team-img-box img {
        width: 160px;
        height: 160px;
        object-fit: cover;
        border: 5px solid white;
        transition: all 0.4s ease;
    }

    .team-card:hover .team-img-box img {
        transform: scale(1.1);
        border-color: var(--accent-orange);
    }

    .social-links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background-color: #f1f1f1;
        color: var(--primary-blue);
        border-radius: 50%;
        margin: 0 5px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .social-links a:hover {
            background-color: var(--accent-orange);
            color: white;
            transform: translateY(-5px);
        }

    /* Hiệu ứng Chạy chữ ngang (Marquee) */
    .marquee-wrapper {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .marquee-track {
        display: flex;
        width: max-content;
        animation: scrollLeft 20s linear infinite;
    }

        .marquee-track:hover {
            animation-play-state: paused;
        }

    @@keyframes scrollLeft {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

    /* Hình nền cho phần CTA */
    .cta-section {
        background-image: url('https://images.unsplash.com/photo-1542361345-89e58247f2d5?auto=format&fit=crop&q=80&w=1920');
        background-attachment: fixed;
        background-position: center;
        background-size: cover;
    }

    /* Căn chỉnh Mobile */
    @@media (max-width: 768px) {
        .safeguard-card {
            transform: scale(1);
            margin-top: 20px;
        }

            .safeguard-card:hover {
                transform: scale(1.02);
            }
    }
</style>