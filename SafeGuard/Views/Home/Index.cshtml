@{
    ViewBag.Title = "Trang Chủ - SafeGuard";
}

<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/Content/images/Banner1.jpg" class="d-block w-100" alt="Lửa">
            <div class="carousel-caption d-none d-md-block text-center">
                <h1>Hệ Thống Tự Động Giám Sát Và Cảnh Báo <br>Nguy Cơ Cháy <span class="highlight-text">Phòng Trọ & Ký Túc Xá</span></h1>
                <p class="fs-4 mt-3">Phát hiện sớm - Cảnh báo tức thì - Bảo vệ sinh mạng và tài sản</p>
                <a href="#" class="btn btn-danger btn-lg mt-3 rounded-pill px-5">Xem Giải Pháp</a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/Content/images/Banner2.jpg" class="d-block w-100" alt="Cảm biến">
            <div class="carousel-caption d-none d-md-block">
                <h1>Công Nghệ <span class="highlight-text">Cảm Biến Khói & Nhiệt</span> Đám Mây</h1>
                <p class="fs-4 mt-3">Giám sát 24/7 thông qua ứng dụng di động và hệ thống web trung tâm.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/Content/images/Banner3.jpg" class="d-block w-100" alt="Ký túc xá">
            <div class="carousel-caption d-none d-md-block">
                <h1>An Tâm Sinh Sống Tại <span class="highlight-text">Ký Túc Xá Sinh Viên</span></h1>
                <p class="fs-4 mt-3">Tự động liên kết với ban quản lý và trạm cứu hỏa gần nhất khi có sự cố.</p>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Trước</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sau</span>
    </button>
</div>

<section class="py-5 bg-white mt-4">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold" style="color: var(--primary-blue);">Bảo Vệ Toàn Diện Khỏi Giặc Lửa</h2>
            <p class="lead text-muted">Hệ thống thông minh tự động hóa mọi quy trình an toàn</p>
        </div>

        <div class="row g-4 text-center">
            <div class="col-md-6">
                <div class="card h-100 p-4 feature-card shadow-sm rounded-4 border-0 bg-light">
                    <div class="icon-wrapper mx-auto mb-4 text-white" style="background: linear-gradient(135deg, #ff416c, #ff4b2b);">
                        <i class="fa-solid fa-bell-concierge fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Cảnh Báo Tức Thì</h4>
                    <p class="text-muted">Gửi tin nhắn SMS, Zalo và gọi điện trực tiếp cho chủ nhà ngay khi phát hiện nồng độ khói bất thường.</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card h-100 p-4 feature-card shadow-sm rounded-4 border-0 bg-light">
                    <div class="icon-wrapper mx-auto mb-4 text-white" style="background: linear-gradient(135deg, #4A00E0, #8E2DE2);">
                        <i class="fa-solid fa-mobile-screen fa-2x"></i>
                    </div>
                    <h4 class="fw-bold">Giám Sát Từ Xa</h4>
                    <p class="text-muted">Theo dõi trực tiếp nhiệt độ, nồng độ khí Gas qua điện thoại mọi lúc mọi nơi.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold" style="color: var(--primary-blue);">Tại Sao Chọn SafeGuard?</h2>
            <p class="lead text-muted">Sự khác biệt rõ rệt giữa công nghệ 4.0 và thiết bị truyền thống</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-5">
                <div class="card h-100 border-0 shadow-sm compare-card traditional-card">
                    <div class="card-header bg-secondary text-white text-center py-4">
                        <h4 class="mb-0">Báo Cháy Truyền Thống</h4>
                    </div>
                    <div class="card-body p-4">
                        <ul class="list-unstyled mb-0 compare-list">
                            <li><i class="fa-solid fa-xmark text-danger me-3"></i> Chỉ kêu chuông báo động tại chỗ</li>
                            <li><i class="fa-solid fa-xmark text-danger me-3"></i> Không có kết nối Internet / Wifi</li>
                            <li><i class="fa-solid fa-xmark text-danger me-3"></i> Tỷ lệ báo cháy giả (sai lệch) cao</li>
                            <li><i class="fa-solid fa-xmark text-danger me-3"></i> Không thể tắt/bật từ xa qua điện thoại</li>
                            <li><i class="fa-solid fa-xmark text-danger me-3"></i> Không tự động gọi cứu hỏa 114</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card h-100 shadow-lg compare-card safeguard-card">
                    <div class="card-header text-white text-center py-4" style="background-color: var(--accent-orange);">
                        <h4 class="mb-0"><i class="fa-solid fa-star text-warning me-2"></i>Hệ Thống SafeGuard</h4>
                    </div>
                    <div class="card-body p-4" style="background-color: #fffdfa;">
                        <ul class="list-unstyled mb-0 compare-list fw-bold text-dark">
                            <li><i class="fa-solid fa-check text-success me-3 fa-lg"></i> Cảnh báo đa kênh (App, SMS, Cuộc gọi)</li>
                            <li><i class="fa-solid fa-check text-success me-3 fa-lg"></i> Kết nối IoT Đám mây 24/7</li>
                            <li><i class="fa-solid fa-check text-success me-3 fa-lg"></i> Cảm biến AI phân tích khói/nhiệt độ chuẩn xác</li>
                            <li><i class="fa-solid fa-check text-success me-3 fa-lg"></i> Giám sát và điều khiển toàn bộ qua App</li>                          
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

