@{
    ViewBag.Title = "Tin Tức & Cảnh Báo - SafeGuard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-header py-5 text-white text-center position-relative">
    <div class="container position-relative" style="z-index: 2;">
        <h1 class="display-4 fw-bold mb-3"><i class="fa-regular fa-newspaper text-warning me-3"></i>Tin Tức PCCC Mới Nhất</h1>
        <p class="lead w-75 mx-auto">Cập nhật liên tục các cảnh báo an toàn, tình hình cháy nổ tại các khu dân cư, phòng trọ và kiến thức phòng cháy chữa cháy năm 2026.</p>
    </div>
    <div class="header-overlay"></div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 news-card">
                    <div class="position-relative">
                        <img src="https://images.unsplash.com/photo-1548142223-c90a19fa640f?auto=format&fit=crop&q=80&w=1200" class="card-img-top" alt="Cháy nhà trọ" style="height: 400px; object-fit: cover;">
                        <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-3 py-2 fs-6">Nóng</span>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <div class="d-flex text-muted mb-3 fs-6">
                            <span class="me-4"><i class="fa-regular fa-calendar me-2"></i>Tháng 3, 2026</span>
                            <span><i class="fa-regular fa-folder-open me-2"></i>Cảnh báo nhà trọ</span>
                        </div>
                        <h2 class="card-title fw-bold mb-3" style="color: var(--primary-blue);">Ám ảnh các vụ cháy nhà trọ: Hậu quả thảm khốc từ sự cố xe điện và chập mạch</h2>
                        <p class="card-text text-muted fs-5 mb-4">Hồi chuông cảnh tỉnh tiếp tục gióng lên khi Tòa án chuẩn bị xét xử lại vụ hỏa hoạn thương tâm tại một nhà trọ ở phố Trung Kính khiến 15 người thiệt mạng. Đa số các khu trọ hiện nay đều thiếu lối thoát hiểm và không có hệ thống cảnh báo khói tự động, dẫn đến việc người dân không kịp phản ứng khi ngọn lửa bùng phát lúc rạng sáng.</p>
                        <a href="#" class="btn btn-outline-danger rounded-pill px-4">Đọc tiếp <i class="fa-solid fa-arrow-right ms-2"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-flex flex-column gap-4">

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden news-card">
                    <img src="https://images.unsplash.com/photo-1582139329536-e7284fece509?auto=format&fit=crop&q=80&w=600" class="card-img-top" alt="Thống kê cháy nổ" style="height: 200px; object-fit: cover;">
                    <div class="card-body p-4">
                        <span class="badge bg-warning text-dark mb-2">Thống kê 2026</span>
                        <h5 class="card-title fw-bold">Báo động: 258 vụ cháy trên toàn quốc chỉ trong tháng 1/2026</h5>
                        <p class="card-text text-muted small">Theo thông cáo báo chí từ Cục Cảnh sát PCCC, đầu năm 2026 ghi nhận con số thiệt hại lớn về tài sản lên đến gần 200 tỷ đồng. Đáng chú ý, 75% nguyên nhân các vụ hỏa hoạn xuất phát từ sự cố hệ thống và thiết bị điện tại hộ gia đình.</p>
                    </div>
                </div>

                <div class="card border-0 shadow-sm rounded-4 overflow-hidden news-card">
                    <img src="https://images.unsplash.com/photo-1605814526284-cd9dcf0440b6?auto=format&fit=crop&q=80&w=600" class="card-img-top" alt="Cháy TP Thủ Đức" style="height: 200px; object-fit: cover;">
                    <div class="card-body p-4">
                        <span class="badge bg-secondary mb-2">Tin Địa Phương</span>
                        <h5 class="card-title fw-bold">TP.HCM: Liên tiếp xảy ra cháy lớn tại các khu xưởng và bãi tập kết</h5>
                        <p class="card-text text-muted small">Cuối tháng 3/2026, các vụ hỏa hoạn bùng phát dữ dội tại bãi tập kết nilon ở phường Linh Xuân (Thủ Đức) và nhà xưởng công ty khiến người dân khu vực hoảng loạn. Rất may không có thiệt hại về người nhưng tài sản bị thiêu rụi hoàn toàn.</p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<style>
    /* Kế thừa Header Overlay */
    .page-header {
        background-image: url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=1920');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 51, 102, 0.85);
        z-index: 1;
    }

    /* Hiệu ứng cho thẻ tin tức */
    .news-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .news-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15) !important;
        }

        .news-card img {
            transition: transform 0.5s ease;
        }

        .news-card:hover img {
            transform: scale(1.05);
        }
</style>