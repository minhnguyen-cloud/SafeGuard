<style>
    /* Kế thừa Header Overlay */
    .page-header {
        background-image: url('https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&q=80&w=1920');
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
    }

    .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 51, 102, 0.85);
