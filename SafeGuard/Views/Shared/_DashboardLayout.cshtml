<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SafeGuard Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="shortcut icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />
    <link rel="icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />

    <link rel="shortcut icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />
    <link rel="icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />
    <style>
        :root {
            --bg-body: #f4f7f6;
            --bg-sidebar: #ffffff;
            --primary-blue: #0d6efd;
            --menu-active-bg: #e9f2ff;
            --menu-active-text: #0b5ed7;
            --border-color: #eef2f5;
        }

        body {
            background-color: var(--bg-body);
            font-family: 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }

        /* Animation */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .anim-fade-up {
            animation: fadeInUp 0.6s ease forwards;
            opacity: 0;
        }

        .delay-1 {
            animation-delay: 0.1s;
        }

        .delay-2 {
            animation-delay: 0.2s;
        }

        .wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 20px;
            font-size: 1.5rem;
            font-weight: bold;
            border-bottom: 1px solid var(--border-color);
        }

            .sidebar-header i {
                color: #ff5722;
            }

        .menu-list {
            list-style: none;
            padding: 15px 10px;
            flex-grow: 1;
            overflow-y: auto;
        }

            .menu-list li a {
                display: flex;
                align-items: center;
                padding: 12px 15px;
                color: #555;
                text-decoration: none;
                border-radius: 8px;
                margin-bottom: 5px;
                font-weight: 500;
                transition: 0.3s;
            }

                .menu-list li a i {
                    width: 25px;
                    font-size: 1.1rem;
                }

                .menu-list li a:hover {
                    background: #f8f9fa;
                    color: #333;
                }

                .menu-list li a.active {
                    background: var(--menu-active-bg);
                    color: var(--menu-active-text);
                    font-weight: 600;
                }

        .nav-reboot {
            border-top: 1px solid #eee;
            margin-top: 15px;
            padding-top: 15px;
        }

            .nav-reboot a {
                color: #dc3545 !important;
            }

        /* Main content */
        .main-content {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            background: #fff;
            height: 70px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        /* Avatar Initials Style */
        .avatar-circle {
            width: 42px;
            height: 42px;
            background-color: var(--primary-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .initials {
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        /* Floating Buttons */
        .floating-hotline-114 {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background: linear-gradient(135deg, #dc3545, #b02a37);
            color: white;
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 900;
            box-shadow: 0 10px 25px rgba(220, 53, 69, 0.5);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            transition: 0.3s;
        }

            .floating-hotline-114:hover {
                color: white;
                transform: scale(1.1);
            }

            .floating-hotline-114 i {
                animation: shake 1s infinite;
            }

        @@keyframes shake {
            0%, 100% {
                transform: rotate(0deg);
            }

            25% {
                transform: rotate(-15deg);
            }

            50% {
                transform: rotate(15deg);
            }

            75% {
                transform: rotate(-15deg);
            }
        }

        .bql-fab-wrapper {
            position: fixed;
            bottom: 100px;
            left: 30px;
            z-index: 9998;
        }

        .bql-fab {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background-color: #0d6efd;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            cursor: pointer;
        }

        .bql-popup {
            display: none;
            width: 280px;
            background-color: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            margin-bottom: 15px;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .bql-popup.show {
                display: block;
                animation: fadeInUp 0.4s ease;
            }

        .firebase-alert-banner {
            display: none;
            position: sticky;
            top: 0;
            z-index: 1055;
            margin: 0 1.5rem 1rem;
            padding: 1rem 1.25rem;
            border-radius: 16px;
            background: linear-gradient(135deg, #fff1f2, #fecaca);
            border: 1px solid #f87171;
            color: #991b1b;
            box-shadow: 0 12px 24px rgba(220, 38, 38, 0.16);
        }

        .firebase-alert-banner.show {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .firebase-alert-banner__title {
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .firebase-alert-banner__meta {
            font-size: 0.92rem;
            color: #7f1d1d;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <nav class="sidebar">
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Home")" style="text-decoration: none; color: inherit; display: block;">
                    <i class="fa-solid fa-fire-flame-curved"></i> SafeGuard
                </a>
            </div>

            @{
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                var currentUserGroup = Session["UserGroup"]?.ToString();
            }

            <ul class="menu-list">
                <li>
                    <a href="@(currentUserGroup == "ADMIN" ? Url.Action("Index", "Admin") : Url.Action("Index", "Tenant"))"
                       class="@(currentAction == "Index" ? "active" : "")">
                        <i class="fa-solid fa-house"></i> Tổng Quan
                    </a>
                </li>

                @if (currentUserGroup == "ADMIN")
                {
                    <li><a href="@Url.Action("QuanLyDayTro", "Admin")" class="@(currentAction == "QuanLyDayTro" ? "active" : "")"><i class="fa-solid fa-building-user"></i> Quản Lý Dãy Trọ</a></li>
                    <li><a href="@Url.Action("QuanLyPhong", "Admin")" class="@(currentAction == "QuanLyPhong" ? "active" : "")"><i class="fa-solid fa-border-all"></i> Quản Lý Phòng</a></li>
                    <li><a href="@Url.Action("TaoMaKichHoat", "Admin")" class="@(currentAction == "TaoMaKichHoat" ? "active" : "")"><i class="fa-solid fa-link"></i> Tạo Mã Kích Hoạt</a></li>
                    <li><a href="@Url.Action("LichSuCanhBao", "Admin")" class="@(currentAction == "LichSuCanhBao" ? "active" : "")"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Cảnh Báo</a></li>
                    <li><a href="@Url.Action("BaoCaoAI", "Admin")" class="@(currentAction == "BaoCaoAI" ? "active" : "")"><i class="fa-solid fa-file-invoice"></i> Báo Cáo AI & Thống Kê</a></li>
                }
                else
                {
                    <li><a href="@Url.Action("LichSuCanhBao", "Tenant")" class="@(currentAction == "LichSuCanhBao" ? "active" : "")"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Cảnh Báo</a></li>
                    <li><a href="@Url.Action("QuanLyPhong", "Tenant")" class="@(currentAction == "QuanLyPhong" ? "active" : "")"><i class="fa-solid fa-door-open"></i> Quản Lý Phòng</a></li>
                    <li><a href="@Url.Action("PhanTichAI", "Tenant")" class="@(currentAction == "PhanTichAI" ? "active" : "")"><i class="fa-solid fa-microchip"></i> Phân Tích AI</a></li>
                    <li><a href="@Url.Action("ThongTinCaNhan", "Tenant")" class="@(currentAction == "ThongTinCaNhan" ? "active" : "")"><i class="fa-solid fa-user-pen"></i> Thông Tin Cá Nhân</a></li>
                }

                <li class="nav-reboot">
                    <a href="javascript:void(0)" onclick="location.reload()">
                        <i class="fa-solid fa-power-off"></i> Tải lại hệ thống
                    </a>
                </li>
            </ul>
        </nav>

        <div class="main-content">
            <div class="topbar">
                <div class="fw-bold text-muted">@ViewBag.Title</div>
                <div class="d-flex align-items-center">
                    <div class="user-profile d-flex align-items-center me-3">
                        @{
                            // Đồng bộ với AccountController: Lấy email từ Session["UserEmail"]
                            string displayIdentifier = Session["UserEmail"]?.ToString() ?? "User";
                            string initials = "";

                            // Tách lấy chữ cái đầu (Ví dụ: tri@gmail.com -> TR)
                            if (displayIdentifier.Contains("@"))
                            {
                                var namePart = displayIdentifier.Split('@')[0];
                                initials = namePart.Length >= 2 ? namePart.Substring(0, 2) : namePart;
                            }
                            else
                            {
                                initials = displayIdentifier.Substring(0, Math.Min(2, displayIdentifier.Length));
                            }
                            initials = initials.ToUpper();
                        }

                        <div class="avatar-circle me-2">
                            <span class="initials">@initials</span>
                        </div>

                        <div>
                            <span class="d-block fw-bold" style="font-size: 0.9rem;">@displayIdentifier</span>
                            <small class="text-muted">@(currentUserGroup == "ADMIN" ? "Chủ Trọ" : "Người Thuê")</small>
                        </div>
                    </div>
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-secondary btn-sm rounded-pill">Đăng xuất</a>
                </div>
            </div>

            <div id="firebaseAlertBanner" class="firebase-alert-banner" role="alert" aria-live="assertive">
                <div>
                    <div class="firebase-alert-banner__title">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>CẢNH BÁO NHIỆT ĐỘ TỪ SAFEGUARD
                    </div>
                    <div id="firebaseAlertMessage" class="mt-1">
                        Hệ thống đang kiểm tra tín hiệu cảnh báo.
                    </div>
                    <div id="firebaseAlertMeta" class="firebase-alert-banner__meta mt-2"></div>
                </div>
                <button type="button" id="firebaseAlertDismiss" class="btn btn-sm btn-outline-danger rounded-pill">Ẩn</button>
            </div>

            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <div class="bql-fab-wrapper">
        <div class="bql-popup shadow-lg" id="globalBqlPopup">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary text-white p-2 rounded-circle me-3"><i class="fa-solid fa-headset"></i></div>
                <h6 class="fw-bold mb-0">HỖ TRỢ 24/7</h6>
            </div>
            <div class="bg-light p-2 rounded mb-2 small border-start border-primary border-3">
                Trực ban: <strong>090.XXX.XXXX</strong>
            </div>
            <div class="bg-light p-2 rounded small border-start border-secondary border-3">
                Kỹ thuật: <strong>028.XXX.XXXX</strong>
            </div>
        </div>
        <button type="button" class="bql-fab" id="globalBqlFabBtn"><i class="fa-solid fa-headset"></i></button>
    </div>

    <a href="tel:114" class="floating-hotline-114"><i class="fa-solid fa-phone"></i> <span>GỌI 114</span></a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#globalBqlFabBtn').click(function () {
                $('#globalBqlPopup').toggleClass('show');
            });
            $(document).click(function (e) {
                if (!$(e.target).closest('.bql-fab-wrapper').length) $('#globalBqlPopup').removeClass('show');
            });

            const firebaseDbUrl = '@(System.Configuration.ConfigurationManager.AppSettings["FirebaseRealtimeDatabaseUrl"] ?? "")';
            const currentUserGroup = '@(currentUserGroup ?? "")';
            const currentAssignedRoom = '@(Session["AssignedRoom"]?.ToString() ?? "")';
            const $firebaseBanner = $('#firebaseAlertBanner');
            const $firebaseMessage = $('#firebaseAlertMessage');
            const $firebaseMeta = $('#firebaseAlertMeta');
            let lastAlertKey = '';
            let isDismissed = false;

            function buildAlertKey(alerts) {
                return (alerts || []).map(function (payload) {
                    return [
                        payload.RoomId || '',
                        payload.Temperature || '',
                        payload.TriggeredAt || '',
                        payload.Source || ''
                    ].join('|');
                }).join('||');
            }

            function hideFirebaseAlert() {
                $firebaseBanner.removeClass('show');
            }

            function formatVietnamAlertTime(utcIsoString) {
                if (!utcIsoString) {
                    return '';
                }

                const utcDate = new Date(utcIsoString);
                if (Number.isNaN(utcDate.getTime())) {
                    return utcIsoString;
                }

                return new Intl.DateTimeFormat('vi-VN', {
                    timeZone: 'Asia/Ho_Chi_Minh',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour12: false
                }).format(utcDate);
            }

            function showFirebaseAlert(alerts, systemNote) {
                const firstAlert = alerts[0] || {};
                const roomList = alerts.map(function (x) { return x.RoomId || 'Chưa rõ phòng'; });
                const roomSummary = roomList.slice(0, 5).join(', ') + (roomList.length > 5 ? '...' : '');
                const maxTemperature = Math.max.apply(null, alerts.map(function (x) { return Number(x.Temperature || 0); }));
                const note = firstAlert.Note || systemNote || 'Phát hiện nhiệt độ vượt ngưỡng.';
                const triggeredAt = formatVietnamAlertTime(firstAlert.TriggeredAt || '');
                const alertKey = buildAlertKey(alerts);

                if (isDismissed && lastAlertKey === alertKey) {
                    return;
                }

                $firebaseMessage.text(`${note} Đang có ${alerts.length} phòng cảnh báo. Mức cao nhất: ${maxTemperature}°C.`);
                $firebaseMeta.text(`Phòng: ${roomSummary}${triggeredAt ? ' | Thời gian: ' + triggeredAt : ''}`);
                $firebaseBanner.addClass('show');

                if (lastAlertKey !== alertKey) {
                    lastAlertKey = alertKey;
                    isDismissed = false;

                    Swal.fire({
                        icon: 'warning',
                        title: 'Cảnh báo nhiệt độ cao',
                        text: `${alerts.length} phòng đang vượt 50°C. Danh sách: ${roomSummary}.`,
                        confirmButtonText: 'Đã hiểu'
                    });
                }
            }

            function normalizeActiveAlerts(systemData) {
                const activeAlerts = systemData && systemData.ActiveAlerts ? Object.keys(systemData.ActiveAlerts).map(function (key) {
                    return systemData.ActiveAlerts[key];
                }) : [];

                return activeAlerts
                    .filter(function (x) { return x && Number(x.Temperature || 0) >= 50; })
                    .sort(function (a, b) { return Number(b.Temperature || 0) - Number(a.Temperature || 0); });
            }

            function syncFirebaseAlert() {
                if (!firebaseDbUrl) {
                    hideFirebaseAlert();
                    return;
                }

                $.getJSON(firebaseDbUrl.replace(/\/$/, '') + '/System.json')
                    .done(function (systemData) {
                        const activeAlerts = normalizeActiveAlerts(systemData);
                        const visibleAlerts = currentUserGroup === 'TENANT'
                            ? activeAlerts.filter(function (x) {
                                return (x.RoomId || '').toUpperCase() === currentAssignedRoom.toUpperCase();
                            })
                            : activeAlerts;

                        if (!systemData || Number(systemData.AlarmStatus) <= 0 || visibleAlerts.length === 0) {
                            lastAlertKey = '';
                            if (!isDismissed) {
                                hideFirebaseAlert();
                            }
                            return;
                        }

                        showFirebaseAlert(visibleAlerts, systemData.Note || '');
                    })
                    .fail(function () {
                        hideFirebaseAlert();
                    });
            }

            $('#firebaseAlertDismiss').on('click', function () {
                isDismissed = true;
                hideFirebaseAlert();
            });

            syncFirebaseAlert();
            setInterval(syncFirebaseAlert, 3000);
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
