<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SafeGuard Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --bg-body: #f4f7f6;
            --bg-sidebar: #ffffff;
            --primary-blue: #0d6efd;
            --menu-active-bg: #e9f2ff;
            --menu-active-text: #0b5ed7;
            --border-color: #eef2f5;
        }

        body {
            background-color: var(--bg-body);
            font-family: 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }

        /* Animation xuất hiện mượt mà */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .anim-fade-up {
            animation: fadeInUp 0.6s ease forwards;
            opacity: 0;
        }

        .delay-1 {
            animation-delay: 0.1s;
        }

        .delay-2 {
            animation-delay: 0.2s;
        }

        .delay-3 {
            animation-delay: 0.3s;
        }

        /* Layout Flexbox */
        .wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 20px;
            font-size: 1.5rem;
            font-weight: bold;
            border-bottom: 1px solid var(--border-color);
        }

            .sidebar-header i {
                color: #ff5722;
            }

        .menu-list {
            list-style: none;
            padding: 15px 10px;
            margin: 0;
        }

            .menu-list li a {
                display: flex;
                align-items: center;
                padding: 12px 15px;
                color: #555;
                text-decoration: none;
                border-radius: 8px;
                margin-bottom: 5px;
                font-weight: 500;
                transition: 0.3s;
            }

                .menu-list li a i {
                    width: 25px;
                    font-size: 1.1rem;
                }

                .menu-list li a:hover {
                    background: #f8f9fa;
                    color: #333;
                }

                .menu-list li a.active {
                    background: var(--menu-active-bg);
                    color: var(--menu-active-text);
                    font-weight: 600;
                }

        /* Nội dung chính */
        .main-content {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            background: #fff;
            height: 70px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        .user-profile img {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            margin-right: 10px;
        }

        /* Card Custom */
        .custom-card {
            border: 1px solid var(--border-color);
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
            background: #fff;
            height: 100%;
        }

        .card-title-custom {
            font-size: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            color: #333;
            margin-bottom: 15px;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            display: inline-block;
        }

        .bg-green {
            background-color: #28a745;
        }

        .bg-red {
            background-color: #dc3545;
        }

        .bg-gray {
            background-color: #6c757d;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <nav class="sidebar">
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Home")" style="text-decoration: none; color: inherit; display: block;">
                    <i class="fa-solid fa-fire-flame-curved"></i> SafeGuard
                </a>
            </div>
            @{
                // Lấy tên trang (Action) hiện tại đang đứng để tự động bôi xanh menu
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                var currentUserGroup = Session["UserGroup"]?.ToString();
            }

            <ul class="menu-list">
                <li>
                    <a href="@(currentUserGroup == "ADMIN" ? Url.Action("Index", "Admin") : Url.Action("Index", "Tenant"))"
                       class="@(currentAction == "Index" ? "active" : "")">
                        <i class="fa-solid fa-house"></i> Tổng Quan
                    </a>
                </li>

                @if (currentUserGroup == "ADMIN")
                {
                    <li>
                        <a href="@Url.Action("QuanLyDayTro", "Admin")" class="@(currentAction == "QuanLyDayTro" ? "active" : "")">
                            <i class="fa-solid fa-building-user"></i> Quản Lý Dãy Trọ
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("QuanLyPhong", "Admin")" class="@(currentAction == "QuanLyPhong" ? "active" : "")">
                            <i class="fa-solid fa-border-all"></i> Quản Lý Phòng & Cảm Biến
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("TaoMaKichHoat", "Admin")" class="@(currentAction == "TaoMaKichHoat" ? "active" : "")">
                            <i class="fa-solid fa-link"></i> Tạo Mã Kích Hoạt
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("LichSuCanhBao", "Admin")" class="@(currentAction == "LichSuCanhBao" ? "active" : "")">
                            <i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Cảnh Báo
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("BaoCaoAI", "Admin")" class="@(currentAction == "BaoCaoAI" ? "active" : "")">
                            <i class="fa-solid fa-file-invoice"></i> Báo Cáo AI & Thống Kê
                        </a>
                    </li>
                }
                else
                {
                    <li>
                        <a href="@Url.Action("LichSuCanhBao", "Tenant")" class="@(currentAction == "LichSuCanhBao" ? "active" : "")">
                            <i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Cảnh Báo
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("QuanLyPhong", "Tenant")" class="@(currentAction == "QuanLyPhong" ? "active" : "")">
                            <i class="fa-solid fa-door-open"></i> Quản Lý Phòng Của Tôi
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("PhanTichAI", "Tenant")" class="@(currentAction == "PhanTichAI" ? "active" : "")">
                            <i class="fa-solid fa-microchip"></i> Phân Tích AI
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ThongTinCaNhan", "Tenant")" class="@(currentAction == "ThongTinCaNhan" ? "active" : "")">
                            <i class="fa-solid fa-user-pen"></i> Thông Tin Cá Nhân
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("NoiQuy", "Tenant")" class="@(currentAction == "NoiQuy" ? "active" : "")">
                            <i class="fa-solid fa-book-open"></i> Nội Quy PCCC
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <div class="main-content">
            <div class="topbar">
                <div class="fw-bold text-muted">@ViewBag.Title</div>
                <div class="d-flex align-items-center">
                    <div class="user-profile d-flex align-items-center me-3">
                        <img src="https://ui-avatars.com/api/?name=@Session["UserEmail"]&background=random" alt="Avatar">
                        <div>
                            <span class="d-block fw-bold" style="font-size: 0.9rem;">
                                @(Session["UserGroup"]?.ToString() == "ADMIN" ? "Chủ Trọ" : "Người Thuê")
                            </span>
                            <small class="text-muted">@Session["UserEmail"]</small>
                        </div>
                    </div>
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-secondary btn-sm">Đăng xuất</a>
                </div>
            </div>

            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
    <style>
        /* 1. NÚT NỔI HOTLINE GÓC TRÁI (114) */
        .floating-hotline-114 {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background: linear-gradient(135deg, #dc3545, #b02a37);
            color: white;
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 900;
            box-shadow: 0 10px 25px rgba(220, 53, 69, 0.5);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            transition: all 0.3s;
        }

            .floating-hotline-114:hover {
                color: white;
                transform: scale(1.1) !important;
                text-decoration: none;
            }

            .floating-hotline-114 i {
                font-size: 1.4rem;
                animation: shake 1s infinite;
            }

        @@keyframes shake {
            0% {
                transform: rotate(0deg);
            }

            25% {
                transform: rotate(-15deg);
            }

            50% {
                transform: rotate(15deg);
            }

            75% {
                transform: rotate(-15deg);
            }

            100% {
                transform: rotate(0deg);
            }
        }

        /* 2. CẤU TRÚC NÚT NỔI TRÒN VÀ POPUP BQL */
        .bql-fab-wrapper {
            position: fixed;
            bottom: 100px;
            left: 30px;
            z-index: 9998;
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }

        .bql-fab {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background-color: #0d6efd;
            color: white;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            animation: pulse-blue-fab 2s infinite;
        }

            .bql-fab:hover {
                background-color: #0a58ca;
                transform: scale(1.1);
            }

            .bql-fab.active {
                background-color: #6c757d;
                transform: rotate(45deg);
            }

        @@keyframes pulse-blue-fab {
            0% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.6);
            }

            70% {
                transform: scale(1.05);
                box-shadow: 0 0 0 12px rgba(13, 110, 253, 0);
            }

            100% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(13, 110, 253, 0);
            }
        }

        .bql-popup {
            display: none;
            width: 280px;
            background-color: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            margin-top: -310px;
            transform: translateY(10px);
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(0,0,0,0.05);
        }

            .bql-popup.show {
                display: block;
                transform: translateY(0);
                opacity: 1;
            }

        .bql-popup-header {
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding-bottom: 15px;
            margin-bottom: 15px;
        }

        .transition-hover {
            transition: all 0.3s ease;
        }

            .transition-hover:hover {
                background-color: #e9ecef !important;
                transform: translateX(5px);
            }
    </style>

    <div class="bql-fab-wrapper">
        <div class="bql-popup shadow-lg" id="globalBqlPopup">
            <div class="bql-popup-header d-flex align-items-center">
                <div class="bg-primary text-primary bg-opacity-10 rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 45px; height: 45px;">
                    <i class="fa-solid fa-headset fs-4"></i>
                </div>
                <div class="ms-3">
                    <span class="badge bg-primary mb-1">HỖ TRỢ 24/7</span>
                    <h6 class="fw-bold text-dark mb-0">BQL SAFEGUARD</h6>
                </div>
                <button type="button" class="btn-close ms-auto small" id="closeGlobalBqlPopup" aria-label="Close" style="font-size: 0.7rem;"></button>
            </div>

            <div class="bg-light rounded-3 p-3 mb-2 transition-hover" style="border-left: 3px solid #0d6efd;">
                <p class="small text-muted mb-0"><i class="fa-solid fa-walkie-talkie me-1"></i> Trực ban tòa nhà:</p>
                <h6 class="fw-bold text-primary mb-0">090.XXX.XXXX</h6>
            </div>

            <div class="bg-light rounded-3 p-3 transition-hover" style="border-left: 3px solid #6c757d;">
                <p class="small text-muted mb-0"><i class="fa-solid fa-screwdriver-wrench me-1"></i> Kỹ thuật NTTU:</p>
                <h6 class="fw-bold text-dark mb-0">028.XXX.XXXX</h6>
            </div>
        </div>

        <button type="button" class="bql-fab" id="globalBqlFabBtn" title="Hỗ trợ BQL SafeGuard">
            <i class="fa-solid fa-headset"></i>
        </button>
    </div>

    <a href="tel:114" class="floating-hotline-114" title="Gọi cứu hỏa khẩn cấp">
        <i class="fa-solid fa-phone"></i>
        <span>GỌI 114</span>
    </a>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const fabBtn = document.getElementById('globalBqlFabBtn');
            const popup = document.getElementById('globalBqlPopup');
            const closeBtn = document.getElementById('closeGlobalBqlPopup');

            if (fabBtn && popup && closeBtn) {
                function togglePopup() {
                    if (popup.classList.contains('show')) {
                        popup.classList.remove('show');
                        fabBtn.classList.remove('active');
                        fabBtn.innerHTML = '<i class="fa-solid fa-headset"></i>';
                    } else {
                        popup.classList.add('show');
                        fabBtn.classList.add('active');
                        fabBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                    }
                }

                fabBtn.addEventListener('click', togglePopup);
                closeBtn.addEventListener('click', togglePopup);

                window.addEventListener('click', function (event) {
                    if (!popup.contains(event.target) && !fabBtn.contains(event.target) && event.target !== fabBtn) {
                        popup.classList.remove('show');
                        fabBtn.classList.remove('active');
                        fabBtn.innerHTML = '<i class="fa-solid fa-headset"></i>';
                    }
                });
            }
        });
    </script>
</body>
</html>