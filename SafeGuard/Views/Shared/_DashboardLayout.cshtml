<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - SafeGuard Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link rel="shortcut icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />
    <link rel="icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />

    <link rel="shortcut icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />
    <link rel="icon" href="~/Content/images/Thuonghieu.png" type="image/x-icon" />
    <style>
        :root {
            --bg-body: #f4f7f6;
            --bg-sidebar: #ffffff;
            --primary-blue: #0d6efd;
            --menu-active-bg: #e9f2ff;
            --menu-active-text: #0b5ed7;
            --border-color: #eef2f5;
        }

        body {
            background-color: var(--bg-body);
            font-family: 'Segoe UI', sans-serif;
            overflow-x: hidden;
        }

        /* Animation */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .anim-fade-up {
            animation: fadeInUp 0.6s ease forwards;
            opacity: 0;
        }

        .delay-1 {
            animation-delay: 0.1s;
        }

        .delay-2 {
            animation-delay: 0.2s;
        }

        .wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            z-index: 1000;
        }

        .sidebar-header {
            padding: 20px;
            font-size: 1.5rem;
            font-weight: bold;
            border-bottom: 1px solid var(--border-color);
        }

            .sidebar-header i {
                color: #ff5722;
            }

        .menu-list {
            list-style: none;
            padding: 15px 10px;
            flex-grow: 1;
            overflow-y: auto;
        }

            .menu-list li a {
                display: flex;
                align-items: center;
                padding: 12px 15px;
                color: #555;
                text-decoration: none;
                border-radius: 8px;
                margin-bottom: 5px;
                font-weight: 500;
                transition: 0.3s;
            }

                .menu-list li a i {
                    width: 25px;
                    font-size: 1.1rem;
                }

                .menu-list li a:hover {
                    background: #f8f9fa;
                    color: #333;
                }

                .menu-list li a.active {
                    background: var(--menu-active-bg);
                    color: var(--menu-active-text);
                    font-weight: 600;
                }

        .nav-reboot {
            border-top: 1px solid #eee;
            margin-top: 15px;
            padding-top: 15px;
        }

            .nav-reboot a {
                color: #dc3545 !important;
            }

        /* Main content */
        .main-content {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
        }

        /* Topbar */
        .topbar {
            background: #fff;
            height: 70px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        /* Avatar Initials Style */
        .avatar-circle {
            width: 42px;
            height: 42px;
            background-color: var(--primary-blue);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            flex-shrink: 0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }

        .initials {
            font-size: 0.9rem;
            letter-spacing: 1px;
        }

        /* Floating Buttons */
        .floating-hotline-114 {
            position: fixed;
            bottom: 30px;
            left: 30px;
            background: linear-gradient(135deg, #dc3545, #b02a37);
            color: white;
            padding: 12px 25px;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 900;
            box-shadow: 0 10px 25px rgba(220, 53, 69, 0.5);
            z-index: 9999;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            transition: 0.3s;
        }

            .floating-hotline-114:hover {
                color: white;
                transform: scale(1.1);
            }

            .floating-hotline-114 i {
                animation: shake 1s infinite;
            }

        @@keyframes shake {
            0%, 100% {
                transform: rotate(0deg);
            }

            25% {
                transform: rotate(-15deg);
            }

            50% {
                transform: rotate(15deg);
            }

            75% {
                transform: rotate(-15deg);
            }
        }

        .bql-fab-wrapper {
            position: fixed;
            bottom: 100px;
            left: 30px;
            z-index: 9998;
        }

        .bql-fab {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            background-color: #0d6efd;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid white;
            box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            cursor: pointer;
        }

        .bql-popup {
            display: none;
            width: 280px;
            background-color: white;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
            margin-bottom: 15px;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .bql-popup.show {
                display: block;
                animation: fadeInUp 0.4s ease;
            }

        .firebase-alert-banner {
            display: none;
            position: sticky;
            top: 0;
            z-index: 1055;
            margin: 0 1.5rem 1rem;
            padding: 1rem 1.15rem;
            border-radius: 8px;
            background: linear-gradient(135deg, #fff1f2 0%, #fee2e2 52%, #fecaca 100%);
            border: 1px solid #ef4444;
            color: #7f1d1d;
            box-shadow: 0 12px 24px rgba(220, 38, 38, 0.16);
        }

        .firebase-alert-banner.show {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            animation: fadeInUp 0.25s ease;
        }

        .firebase-alert-banner__title {
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            color: #991b1b;
        }

        .firebase-alert-banner__meta {
            font-size: 0.92rem;
            color: #7f1d1d;
        }

        .firebase-alert-banner__message {
            font-size: 1rem;
            font-weight: 600;
            color: #7f1d1d;
        }

        #firebaseAlertDismiss {
            flex-shrink: 0;
            border-color: #b91c1c;
            color: #991b1b;
            background: rgba(255, 255, 255, 0.5);
        }

        #firebaseAlertDismiss:hover {
            color: #ffffff;
            background: #b91c1c;
        }

        .safeguard-alert-popup {
            border-radius: 8px !important;
            border: 1px solid #fecaca !important;
            box-shadow: 0 24px 60px rgba(127, 29, 29, 0.22) !important;
        }

        .safeguard-popup-body {
            text-align: left;
            padding: 4px 10px 0;
            color: #7f1d1d;
        }

        .safeguard-popup-body strong {
            color: #991b1b;
        }

        .safeguard-popup-meta {
            margin-top: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            background: #fee2e2;
            border: 1px solid #fecaca;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>

    <div class="wrapper">
        <nav class="sidebar">
            <div class="sidebar-header">
                <a href="@Url.Action("Index", "Home")" style="text-decoration: none; color: inherit; display: block;">
                    <i class="fa-solid fa-fire-flame-curved"></i> SafeGuard
                </a>
            </div>

            @{
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                var currentUserGroup = Session["UserGroup"]?.ToString();
            }

            <ul class="menu-list">
                <li>
                    <a href="@(currentUserGroup == "ADMIN" ? Url.Action("Index", "Admin") : Url.Action("Index", "Tenant"))"
                       class="@(currentAction == "Index" ? "active" : "")">
                        <i class="fa-solid fa-house"></i> Tổng Quan
                    </a>
                </li>

                @if (currentUserGroup == "ADMIN")
                {
                    <li><a href="@Url.Action("QuanLyDayTro", "Admin")" class="@(currentAction == "QuanLyDayTro" ? "active" : "")"><i class="fa-solid fa-building-user"></i> Quản Lý Dãy Trọ</a></li>
                    <li><a href="@Url.Action("QuanLyPhong", "Admin")" class="@(currentAction == "QuanLyPhong" ? "active" : "")"><i class="fa-solid fa-border-all"></i> Quản Lý Phòng</a></li>
                    <li><a href="@Url.Action("TaoMaKichHoat", "Admin")" class="@(currentAction == "TaoMaKichHoat" ? "active" : "")"><i class="fa-solid fa-link"></i> Tạo Mã Kích Hoạt</a></li>
                    <li><a href="@Url.Action("LichSuCanhBao", "Admin")" class="@(currentAction == "LichSuCanhBao" ? "active" : "")"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Cảnh Báo</a></li>
                    <li><a href="@Url.Action("BaoCaoAI", "Admin")" class="@(currentAction == "BaoCaoAI" ? "active" : "")"><i class="fa-solid fa-file-invoice"></i> Báo Cáo AI & Thống Kê</a></li>
                }
                else
                {
                    <li><a href="@Url.Action("LichSuCanhBao", "Tenant")" class="@(currentAction == "LichSuCanhBao" ? "active" : "")"><i class="fa-solid fa-clock-rotate-left"></i> Lịch Sử Cảnh Báo</a></li>
                    <li><a href="@Url.Action("QuanLyPhong", "Tenant")" class="@(currentAction == "QuanLyPhong" ? "active" : "")"><i class="fa-solid fa-door-open"></i> Quản Lý Phòng</a></li>
                    <li><a href="@Url.Action("PhanTichAI", "Tenant")" class="@(currentAction == "PhanTichAI" ? "active" : "")"><i class="fa-solid fa-microchip"></i> Phân Tích AI</a></li>
                    <li><a href="@Url.Action("ThongTinCaNhan", "Tenant")" class="@(currentAction == "ThongTinCaNhan" ? "active" : "")"><i class="fa-solid fa-user-pen"></i> Thông Tin Cá Nhân</a></li>
                }

                <li class="nav-reboot">
                    <a href="javascript:void(0)" onclick="location.reload()">
                        <i class="fa-solid fa-power-off"></i> Tải lại hệ thống
                    </a>
                </li>
            </ul>
        </nav>

        <div class="main-content">
            <div class="topbar">
                <div class="fw-bold text-muted">@ViewBag.Title</div>
                <div class="d-flex align-items-center">
                    <div class="user-profile d-flex align-items-center me-3">
                        @{
                            // Đồng bộ với AccountController: Lấy email từ Session["UserEmail"]
                            string displayIdentifier = Session["UserEmail"]?.ToString() ?? "User";
                            string initials = "";

                            // Tách lấy chữ cái đầu (Ví dụ: tri@gmail.com -> TR)
                            if (displayIdentifier.Contains("@"))
                            {
                                var namePart = displayIdentifier.Split('@')[0];
                                initials = namePart.Length >= 2 ? namePart.Substring(0, 2) : namePart;
                            }
                            else
                            {
                                initials = displayIdentifier.Substring(0, Math.Min(2, displayIdentifier.Length));
                            }
                            initials = initials.ToUpper();
                        }

                        <div class="avatar-circle me-2">
                            <span class="initials">@initials</span>
                        </div>

                        <div>
                            <span class="d-block fw-bold" style="font-size: 0.9rem;">@displayIdentifier</span>
                            <small class="text-muted">@(currentUserGroup == "ADMIN" ? "Chủ Trọ" : "Người Thuê")</small>
                        </div>
                    </div>
                    <a href="@Url.Action("Logout", "Account")" class="btn btn-outline-secondary btn-sm rounded-pill">Đăng xuất</a>
                </div>
            </div>

            <div id="firebaseAlertBanner" class="firebase-alert-banner" role="alert" aria-live="assertive">
                <div>
                    <div class="firebase-alert-banner__title">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>CẢNH BÁO NHIỆT ĐỘ TỪ SAFEGUARD
                    </div>
                    <div id="firebaseAlertMessage" class="firebase-alert-banner__message mt-1">
                        Hệ thống đang kiểm tra tín hiệu cảnh báo.
                    </div>
                    <div id="firebaseAlertMeta" class="firebase-alert-banner__meta mt-2"></div>
                </div>
                <button type="button" id="firebaseAlertDismiss" class="btn btn-sm btn-outline-danger rounded-pill">Ẩn</button>
            </div>

            <div class="p-4">
                @RenderBody()
            </div>
        </div>
    </div>

    <div class="bql-fab-wrapper">
        <div class="bql-popup shadow-lg" id="globalBqlPopup">
            <div class="d-flex align-items-center mb-3">
                <div class="bg-primary text-white p-2 rounded-circle me-3"><i class="fa-solid fa-headset"></i></div>
                <h6 class="fw-bold mb-0">HỖ TRỢ 24/7</h6>
            </div>
            <div class="bg-light p-2 rounded mb-2 small border-start border-primary border-3">
                Trực ban: <strong>090.XXX.XXXX</strong>
            </div>
            <div class="bg-light p-2 rounded small border-start border-secondary border-3">
                Kỹ thuật: <strong>028.XXX.XXXX</strong>
            </div>
        </div>
        <button type="button" class="bql-fab" id="globalBqlFabBtn"><i class="fa-solid fa-headset"></i></button>
    </div>

    <a href="tel:114" class="floating-hotline-114"><i class="fa-solid fa-phone"></i> <span>GỌI 114</span></a>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            $('#globalBqlFabBtn').click(function () {
                $('#globalBqlPopup').toggleClass('show');
            });
            $(document).click(function (e) {
                if (!$(e.target).closest('.bql-fab-wrapper').length) $('#globalBqlPopup').removeClass('show');
            });

            const firebaseDbUrl = '@(System.Configuration.ConfigurationManager.AppSettings["FirebaseRealtimeDatabaseUrl"] ?? "")';
            const currentUserGroup = '@(currentUserGroup ?? "")';
            const currentAssignedRoom = '@(Session["AssignedRoom"]?.ToString() ?? "")';
            const $firebaseBanner = $('#firebaseAlertBanner');
            const $firebaseMessage = $('#firebaseAlertMessage');
            const $firebaseMeta = $('#firebaseAlertMeta');
            const storedRealtimeAlertKey = 'SafeGuard.ActiveRealtimeAlert';
            const storedDismissedAlertKey = 'SafeGuard.DismissedAlertKey';
            window.safeGuardAlertState = window.safeGuardAlertState || {
                lastAlertKey: '',
                dismissedAlertKey: '',
                activeRealtimeAlertKey: '',
                lastPopupKey: '',
                lastPopupAt: 0,
                popupCooldownUntil: 0,
                popupRoomCooldowns: {},
                bannerSource: '',
                hasConnectedWebSocket: false,
                wsConnected: false
            };
            const alertState = window.safeGuardAlertState;
            try {
                alertState.dismissedAlertKey = sessionStorage.getItem(storedDismissedAlertKey) || alertState.dismissedAlertKey || '';
            } catch (e) {
                alertState.dismissedAlertKey = alertState.dismissedAlertKey || '';
            }

            function buildAlertKey(alerts) {
                return (alerts || []).map(function (payload) {
                    return [
                        payload.RoomId || '',
                        payload.Temperature || '',
                        payload.TriggeredAt || '',
                        payload.Source || ''
                    ].join('|');
                }).join('||');
            }

            function hideFirebaseAlert(force) {
                if (!force && alertState.activeRealtimeAlertKey && alertState.dismissedAlertKey !== alertState.activeRealtimeAlertKey) {
                    return;
                }

                $firebaseBanner.removeClass('show');

                if (force) {
                    alertState.bannerSource = '';
                }
            }

            window.hideSafeGuardAlertBanner = hideFirebaseAlert;

            function formatVietnamAlertTime(utcIsoString) {
                if (!utcIsoString) {
                    return '';
                }

                const utcDate = new Date(utcIsoString);
                if (Number.isNaN(utcDate.getTime())) {
                    return utcIsoString;
                }

                return new Intl.DateTimeFormat('vi-VN', {
                    timeZone: 'Asia/Ho_Chi_Minh',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour12: false
                }).format(utcDate);
            }

            window.buildRealtimeAlertKey = function (data) {
                if (data && data.alertKey) {
                    return data.alertKey;
                }

                return [
                    data.type || '',
                    data.roomId || '',
                    data.temperature || '',
                    data.timestamp || '',
                    data.alertLevel || ''
                ].join('|');
            };

            function parseAlertTime(value) {
                if (value === undefined || value === null || value === '') {
                    return null;
                }

                if (typeof value === 'number') {
                    return value < 1000000000000 ? value * 1000 : value;
                }

                const numericValue = Number(value);
                if (!Number.isNaN(numericValue) && value.toString().trim() !== '') {
                    return numericValue < 1000000000000 ? numericValue * 1000 : numericValue;
                }

                const parsedTime = Date.parse(value);
                return Number.isNaN(parsedTime) ? null : parsedTime;
            }

            function isRecentFirebaseAlert(payload) {
                const alertTime = parseAlertTime(payload.TriggeredAt || payload.timestamp || payload.Timestamp);

                if (!alertTime) {
                    return false;
                }

                const ageMs = Date.now() - alertTime;
                return ageMs >= 0 && ageMs <= 10 * 60 * 1000;
            }

            function normalizeFirebaseAlertForStorage(alerts, systemNote) {
                const firstAlert = alerts && alerts.length ? alerts[0] : {};
                const maxTemperature = Math.max.apply(null, (alerts || []).map(function (x) { return Number(x.Temperature || 0); }));
                const roomList = (alerts || []).map(function (x) { return x.RoomId || 'Chưa rõ phòng'; });
                const roomSummary = roomList.slice(0, 5).join(', ') + (roomList.length > 5 ? '...' : '');
                const level = maxTemperature >= 50 ? 'FIRE' : (maxTemperature >= 45 ? 'DANGER' : 'WARNING');

                return {
                    type: 'alert_triggered',
                    source: 'firebase',
                    alertKey: buildAlertKey(alerts),
                    roomId: firstAlert.RoomId || roomSummary || 'Chưa rõ phòng',
                    temperature: maxTemperature,
                    alertLevel: level,
                    triggeredAt: firstAlert.TriggeredAt || new Date().toISOString(),
                    message: firstAlert.Note || systemNote || ('Đang có ' + (alerts || []).length + ' phòng cảnh báo. Mức cao nhất: ' + maxTemperature + '°C.')
                };
            }

            window.isFreshSafeGuardRealtimeEvent = function (data) {
                const eventTime = parseAlertTime(data.timestamp || data.TriggeredAt || data.triggeredAt);

                if (!eventTime) {
                    return true;
                }

                const ageMs = Date.now() - eventTime;
                return ageMs >= -60 * 1000 && ageMs <= 10 * 60 * 1000;
            };

            function rememberRealtimeAlert(data) {
                try {
                    sessionStorage.setItem(storedRealtimeAlertKey, JSON.stringify({
                        storedAt: new Date().toISOString(),
                        data: data
                    }));
                } catch (e) {
                    console.warn('[SafeGuard] Cannot store realtime alert', e);
                }
            }

            function forgetRealtimeAlert() {
                try {
                    sessionStorage.removeItem(storedRealtimeAlertKey);
                } catch (e) {
                    console.warn('[SafeGuard] Cannot clear realtime alert', e);
                }
            }

            function forgetDismissedAlertKey() {
                try {
                    sessionStorage.removeItem(storedDismissedAlertKey);
                } catch (e) {
                    console.warn('[SafeGuard] Cannot clear dismissed alert key', e);
                }
            }

            function restoreRealtimeAlertBanner() {
                try {
                    const raw = sessionStorage.getItem(storedRealtimeAlertKey);
                    if (!raw) {
                        return;
                    }

                    const stored = JSON.parse(raw);
                    const data = stored && stored.data ? stored.data : null;
                    if (!data || data.type === 'room_joined') {
                        forgetRealtimeAlert();
                        return;
                    }

                    const currentKey = window.buildRealtimeAlertKey(data);
                    if (alertState.dismissedAlertKey === currentKey) {
                        return;
                    }

                    window.showPersistentRealtimeBanner(data, false);
                } catch (e) {
                    forgetRealtimeAlert();
                }
            }

            window.showPersistentRealtimeBanner = function (data, shouldRemember) {
                const roomId = data.roomId || 'Chưa rõ phòng';
                const tempText = data.temperature != null ? (data.temperature + '°C') : 'N/A';
                const level = (data.alertLevel || '').toUpperCase();

                alertState.activeRealtimeAlertKey = window.buildRealtimeAlertKey(data);
                alertState.bannerSource = 'websocket';

                if (shouldRemember !== false) {
                    rememberRealtimeAlert(data);
                }

                if ($firebaseBanner.length) {
                    $firebaseMessage.text(data.message || ('Phòng ' + roomId + ' đang có cảnh báo an toàn.'));
                    $firebaseMeta.text(
                        'Phòng: ' + roomId +
                        ' | Nhiệt độ: ' + tempText +
                        (level ? ' | Mức: ' + level : '')
                    );
                    $firebaseBanner.addClass('show');
                }
            };

            window.clearRealtimeBannerIfRecovered = function (data) {
                const level = (data.alertLevel || '').toUpperCase();
                if (level === 'NORMAL') {
                    alertState.activeRealtimeAlertKey = '';
                    alertState.dismissedAlertKey = '';
                    forgetRealtimeAlert();
                    forgetDismissedAlertKey();
                    hideFirebaseAlert(true);
                }
            };

            window.showSafeGuardRealtimePopup = function (data, options) {
                if (!window.Swal) {
                    return;
                }

                options = options || {};

                const level = (data.alertLevel || '').toUpperCase();
                const currentKey = options.popupKey || window.buildRealtimeAlertKey(data);
                const roomPopupKey = options.roomPopupKey || [
                    data.type || '',
                    data.roomId || '',
                    level || ''
                ].join('|');
                const now = Date.now();
                const globalCooldownMs = options.globalCooldownMs || 60000;
                const roomCooldownMs = options.roomCooldownMs || 300000;

                alertState.popupRoomCooldowns = alertState.popupRoomCooldowns || {};

                if (window.Swal.isVisible && window.Swal.isVisible()) {
                    return;
                }

                if (alertState.lastPopupKey === currentKey) {
                    return;
                }

                if (alertState.popupCooldownUntil && now < alertState.popupCooldownUntil) {
                    return;
                }

                if (alertState.popupRoomCooldowns[roomPopupKey] && now < alertState.popupRoomCooldowns[roomPopupKey]) {
                    return;
                }

                alertState.lastPopupKey = currentKey;
                alertState.lastPopupAt = now;
                alertState.popupCooldownUntil = now + globalCooldownMs;
                alertState.popupRoomCooldowns[roomPopupKey] = now + roomCooldownMs;

                Swal.fire({
                    icon: options.icon || 'warning',
                    title: options.title || 'Cảnh báo từ SafeGuard',
                    html: options.html || '',
                    confirmButtonText: 'Đã hiểu',
                    confirmButtonColor: options.confirmButtonColor || '#b91c1c',
                    background: '#fff7f7',
                    color: '#7f1d1d',
                    showClass: {
                        popup: 'animate__animated animate__fadeInDown'
                    },
                    customClass: {
                        popup: 'safeguard-alert-popup'
                    }
                });
            };

            function showFirebaseAlert(alerts, systemNote) {
                const firstAlert = alerts[0] || {};
                const roomList = alerts.map(function (x) { return x.RoomId || 'Chưa rõ phòng'; });
                const roomSummary = roomList.slice(0, 5).join(', ') + (roomList.length > 5 ? '...' : '');
                const maxTemperature = Math.max.apply(null, alerts.map(function (x) { return Number(x.Temperature || 0); }));
                const note = firstAlert.Note || systemNote || 'Phát hiện nhiệt độ vượt ngưỡng.';
                const triggeredAt = formatVietnamAlertTime(firstAlert.TriggeredAt || '');
                const alertKey = buildAlertKey(alerts);

                if (alertState.dismissedAlertKey === alertKey) {
                    return;
                }

                $firebaseMessage.text(`${note} Đang có ${alerts.length} phòng cảnh báo. Mức cao nhất: ${maxTemperature}°C.`);
                $firebaseMeta.text(`Phòng: ${roomSummary}${triggeredAt ? ' | Thời gian: ' + triggeredAt : ''}`);
                $firebaseBanner.addClass('show');
                alertState.bannerSource = 'firebase';
                alertState.activeRealtimeAlertKey = alertKey;
                rememberRealtimeAlert(normalizeFirebaseAlertForStorage(alerts, systemNote));

                if (alertState.lastAlertKey !== alertKey) {
                    alertState.lastAlertKey = alertKey;
                    alertState.dismissedAlertKey = '';
                    forgetDismissedAlertKey();
                }
            }

            function normalizeActiveAlerts(systemData) {
                const activeAlerts = systemData && systemData.ActiveAlerts ? Object.keys(systemData.ActiveAlerts).map(function (key) {
                    return systemData.ActiveAlerts[key];
                }) : [];

                return activeAlerts
                    .filter(function (x) { return x && Number(x.Temperature || 0) >= 50 && isRecentFirebaseAlert(x); })
                    .sort(function (a, b) { return Number(b.Temperature || 0) - Number(a.Temperature || 0); });
            }

            function syncFirebaseAlert(forceInitialSync) {
                const shouldCheckFirebase =
                    forceInitialSync ||
                    alertState.bannerSource === 'firebase' ||
                    !alertState.activeRealtimeAlertKey ||
                    (!alertState.wsConnected && !alertState.hasConnectedWebSocket);

                if (!shouldCheckFirebase) {
                    return;
                }

                if (!firebaseDbUrl) {
                    hideFirebaseAlert();
                    return;
                }

                $.getJSON(firebaseDbUrl.replace(/\/$/, '') + '/System.json')
                    .done(function (systemData) {
                        const activeAlerts = normalizeActiveAlerts(systemData);
                        const visibleAlerts = currentUserGroup === 'TENANT'
                            ? activeAlerts.filter(function (x) {
                                return (x.RoomId || '').toUpperCase() === currentAssignedRoom.toUpperCase();
                            })
                            : activeAlerts;

                        if (!systemData || Number(systemData.AlarmStatus) <= 0 || visibleAlerts.length === 0) {
                            alertState.lastAlertKey = '';
                            if (alertState.bannerSource === 'firebase' || !alertState.activeRealtimeAlertKey) {
                                alertState.activeRealtimeAlertKey = '';
                                forgetRealtimeAlert();
                                hideFirebaseAlert(true);
                            }
                            return;
                        }

                        showFirebaseAlert(visibleAlerts, systemData.Note || '');
                    })
                    .fail(function () {
                        hideFirebaseAlert();
                    });
            }

            $('#firebaseAlertDismiss').on('click', function () {
                alertState.dismissedAlertKey = alertState.activeRealtimeAlertKey || alertState.lastAlertKey || '';
                alertState.activeRealtimeAlertKey = '';
                try {
                    sessionStorage.setItem(storedDismissedAlertKey, alertState.dismissedAlertKey);
                } catch (e) {
                    console.warn('[SafeGuard] Cannot store dismissed alert key', e);
                }
                forgetRealtimeAlert();
                hideFirebaseAlert(true);
            });

            restoreRealtimeAlertBanner();
            setTimeout(function () { syncFirebaseAlert(true); }, 1500);
            setInterval(syncFirebaseAlert, 3000);
        });
    </script>
    <script>
        (function () {
            const role = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Session["UserGroup"]?.ToString() ?? "GUEST"));
            const userId = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Session["UserEmail"]?.ToString() ?? ""));
            const roomId = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Session["AssignedRoom"]?.ToString() ?? ""));

            const wsUrl =
                'wss://6kebk039t7.execute-api.ap-southeast-1.amazonaws.com/prod'
                + '?role=' + encodeURIComponent(role)
                + '&userId=' + encodeURIComponent(userId)
                + '&roomId=' + encodeURIComponent(roomId);

            let socket = null;
            let reconnectTimer = null;

            function connectSafeGuardWs() {
                socket = new WebSocket(wsUrl);

                socket.onopen = function () {
                    window.safeGuardAlertState = window.safeGuardAlertState || {};
                    const alertState = window.safeGuardAlertState;
                    alertState.wsConnected = true;
                    alertState.hasConnectedWebSocket = true;

                    if (alertState.bannerSource === 'firebase' && !alertState.activeRealtimeAlertKey) {
                        alertState.lastAlertKey = '';
                        alertState.dismissedAlertKey = '';
                        alertState.activeRealtimeAlertKey = '';
                        alertState.bannerSource = '';

                        if (window.hideSafeGuardAlertBanner) {
                            window.hideSafeGuardAlertBanner(true);
                        }
                    }

                    console.log('[SafeGuard WS] connected');
                };

                socket.onmessage = function (event) {
                    try {
                        const data = JSON.parse(event.data);
                        console.log('[SafeGuard WS] message:', data);

                        window.dispatchEvent(new CustomEvent('safeguard:realtime', {
                            detail: data
                        }));
                    } catch (e) {
                        console.error('[SafeGuard WS] invalid message', e);
                    }
                };

                socket.onclose = function () {
                    window.safeGuardAlertState = window.safeGuardAlertState || {};
                    window.safeGuardAlertState.wsConnected = false;
                    console.log('[SafeGuard WS] closed, reconnecting...');
                    clearTimeout(reconnectTimer);
                    reconnectTimer = setTimeout(connectSafeGuardWs, 3000);
                };

                socket.onerror = function (err) {
                    console.error('[SafeGuard WS] error', err);
                    try { socket.close(); } catch (e) { }
                };
            }

            connectSafeGuardWs();
        })();
    </script>
    <script>
        window.addEventListener('safeguard:realtime', function (e) {
            const data = e.detail || {};
            console.log('[SafeGuard realtime event]', data);

            const $firebaseBanner = $('#firebaseAlertBanner');
            const $firebaseMessage = $('#firebaseAlertMessage');
            const $firebaseMeta = $('#firebaseAlertMeta');

            if ((data.type === 'alert_triggered' || data.type === 'sensor_update') &&
                window.isFreshSafeGuardRealtimeEvent &&
                !window.isFreshSafeGuardRealtimeEvent(data)) {
                console.log('[SafeGuard realtime event ignored: stale]', data);
                return;
            }

            // 1) Su kien tenant vao phong la thong tin binh thuong, khong hien banner/popup canh bao.
            if (data.type === 'room_joined') {
                if (window.safeGuardAlertState && window.safeGuardAlertState.bannerSource !== 'websocket') {
                    window.hideSafeGuardAlertBanner(true);
                }

                console.log('[SafeGuard room joined]', data);
                return;
            }

            // 2) Canh bao nguy hiem rieng tu WebSocket
            if (data.type === 'alert_triggered') {
                const level = (data.alertLevel || '').toUpperCase();
                const roomId = data.roomId || 'Chưa rõ phòng';
                const currentKey = window.buildRealtimeAlertKey(data);
                const alertState = window.safeGuardAlertState;

                // Luon giu banner neu user chua an dung canh bao nay
                if (alertState.dismissedAlertKey !== currentKey) {
                    window.showPersistentRealtimeBanner(data);
                } else {
                    alertState.activeRealtimeAlertKey = currentKey;
                }

                // Popup chi hien 1 lan cho moi alert key
                if ((level === 'FIRE' || level === 'DANGER') && alertState.lastAlertKey !== currentKey) {
                    alertState.lastAlertKey = currentKey;
                    let title = level === 'FIRE' ? 'Cảnh báo cháy khẩn cấp' : 'Cảnh báo nguy hiểm';

                    window.showSafeGuardRealtimePopup(data, {
                        icon: 'warning',
                        title: title,
                        confirmButtonColor: '#b91c1c',
                        globalCooldownMs: 60000,
                        roomCooldownMs: 300000,
                        html:
                            '<div class="safeguard-popup-body">' +
                            '<strong>' + (data.message || ('Phòng ' + roomId + ' đang có cảnh báo.')) + '</strong>' +
                            '<div class="safeguard-popup-meta">' +
                            'Phòng: ' + roomId +
                            '<br>Nhiệt độ: ' + (data.temperature != null ? data.temperature + '°C' : 'N/A') +
                            (level ? '<br>Mức cảnh báo: ' + level : '') +
                            '<br>Vui lòng kiểm tra thiết bị điện và khu vực xung quanh ngay khi an toàn.' +
                            '</div>' +
                            '</div>'
                    });
                }

                return;
            }

            // 3) Cap nhat cam bien / canh bao nhiet do
            if (data.type === 'sensor_update') {
                const alertLevel = (data.alertLevel || '').toUpperCase();
                const tempText = data.temperature != null ? (data.temperature + '°C') : 'N/A';
                const currentKey = window.buildRealtimeAlertKey(data);
                const alertState = window.safeGuardAlertState;

                // Neu ve NORMAL thi tu clear banner
                window.clearRealtimeBannerIfRecovered(data);

                if ($firebaseBanner.length && alertLevel !== 'NORMAL') {
                    alertState.activeRealtimeAlertKey = currentKey;

                    if (alertState.dismissedAlertKey !== currentKey) {
                        if (alertLevel === 'FIRE' || alertLevel === 'DANGER' || alertLevel === 'WARNING') {
                            window.showPersistentRealtimeBanner(data);
                        }
                    }
                }

                return;
            }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
