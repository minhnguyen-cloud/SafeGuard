@{
    ViewBag.Title = "Đăng Nhập - SafeGuard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="card-header text-center py-4 bg-white border-0">
                        <h2 class="fw-bold mb-0" style="color: var(--primary-blue);">Đăng Nhập</h2>
                        <p class="text-muted mt-2 mb-0">Hệ thống quản lý SafeGuard</p>
                    </div>
                    <div class="card-body p-4 p-md-5 pt-0">
                        <form>
                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted small">Email hoặc Tài khoản</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-regular fa-user"></i></span>
                                    <input type="text" class="form-control border-start-0 ps-0 custom-input" placeholder="Nhập email của bạn">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted small">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-solid fa-lock"></i></span>
                                    <input type="password" class="form-control border-start-0 border-end-0 ps-0 custom-input" id="loginPassword" placeholder="Nhập mật khẩu">
                                    <span class="input-group-text bg-white text-muted border-start-0 custom-eye" onclick="togglePassword('loginPassword', this)">
                                        <i class="fa-solid fa-eye"></i>
                                    </span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="rememberMe">
                                    <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ đăng nhập</label>
                                </div>
                                <a href="@Url.Action("ForgotPassword", "Account")" class="small text-decoration-none" style="color: var(--accent-orange);">Quên mật khẩu?</a>
                            </div>

                            <button type="submit" class="btn w-100 py-3 fw-bold rounded-pill mb-3 text-white" style="background-color: var(--primary-blue);">
                                ĐĂNG NHẬP
                            </button>

                            <p class="text-center text-muted small mb-0">Chưa có tài khoản? <a href="@Url.Action("Register", "Account")" class="fw-bold text-decoration-none" style="color: var(--primary-blue);">Đăng ký ngay</a></p>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>