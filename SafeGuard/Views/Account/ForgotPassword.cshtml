@{
    ViewBag.Title = "Quên Mật Khẩu - SafeGuard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="card-header text-center py-4 bg-white border-0">
                        <div class="mb-3">
                            <i class="fa-solid fa-key fa-3x" style="color: var(--accent-orange);"></i>
                        </div>
                        <h2 class="fw-bold mb-0" style="color: var(--primary-blue);">Khôi Phục Mật Khẩu</h2>
                        <p class="text-muted mt-2 mb-0 px-3">Nhập email đã đăng ký, chúng tôi sẽ gửi liên kết để bạn thiết lập lại mật khẩu an toàn.</p>
                    </div>
                    <div class="card-body p-4 p-md-5 pt-0">
                        <form>
                            <div class="mb-4">
                                <label class="form-label fw-bold text-muted small">Email khôi phục</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white text-muted border-end-0"><i class="fa-regular fa-envelope"></i></span>
                                    <input type="email" class="form-control border-start-0 ps-0 custom-input" placeholder="Nhập email của bạn">
                                </div>
                            </div>

                            <button type="submit" class="btn w-100 py-3 fw-bold rounded-pill mb-4 text-white" style="background-color: var(--primary-blue);">
                                GỬI LIÊN KẾT KHÔI PHỤC
                            </button>

                            <div class="text-center">
                                <a href="@Url.Action("Login", "Account")" class="text-decoration-none text-muted small fw-bold">
                                    <i class="fa-solid fa-arrow-left me-2"></i>Quay lại đăng nhập
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>