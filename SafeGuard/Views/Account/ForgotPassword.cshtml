@model SafeGuard.Models.ForgotPasswordViewModel
@{
    ViewBag.Title = "Quên Mật Khẩu - SafeGuard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light" style="min-height: 80vh; display: flex; align-items: center;">
    <div class="container text-center">
        <div class="card border-0 shadow-lg rounded-4 p-4 mx-auto position-relative" style="max-width: 450px;">

            <a href="@Url.Action("Login", "Account")" class="position-absolute top-0 end-0 p-3 text-muted text-decoration-none" title="Quay lại trang đăng nhập" style="z-index: 10; transition: color 0.2s;" onmouseover="this.style.color='var(--primary-blue)'" onmouseout="this.style.color=''">
                <i class="fa-solid fa-xmark fs-4"></i>
            </a>
            <i class="fa-solid fa-key fa-3x mb-3" style="color: var(--accent-orange);"></i>
            <h2 class="fw-bold">Khôi Phục Mật Khẩu</h2>
            <p class="text-muted">Nhập email, chúng tôi sẽ gửi mã xác nhận 6 số.</p>

            @using (Html.BeginForm("ForgotPassword", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="mb-4 text-start">
                    <label class="small fw-bold">Email khôi phục</label>
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control py-3", placeholder = "Nhập email của bạn" })
                </div>
                <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill">GỬI MÃ XÁC NHẬN</button>
            }

            <div class="mt-3">
                <a href="@Url.Action("Login", "Account")" class="small text-muted text-decoration-none hover-blue"><i class="fa-solid fa-arrow-left me-1"></i> Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
</section>