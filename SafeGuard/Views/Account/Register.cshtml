@model SafeGuard.Models.RegisterViewModel
@{
    ViewBag.Title = "Đăng Ký - SafeGuard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light" style="min-height: 85vh; display: flex; align-items: center;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden position-relative">

                    <a href="@Url.Action("Index", "Home")" class="position-absolute top-0 end-0 p-3 text-muted text-decoration-none" title="Quay lại trang chủ" style="z-index: 10; transition: color 0.2s;" onmouseover="this.style.color='var(--primary-blue)'" onmouseout="this.style.color=''">
                        <i class="fa-solid fa-xmark fs-4"></i>
                    </a>
                    <div class="card-header text-center py-4 bg-white border-0">
                        <h2 class="fw-bold mb-0" style="color: var(--primary-blue);">Tạo Tài Khoản</h2>
                        <p class="text-muted mt-2 mb-0">Bảo vệ ngôi nhà bạn ngay hôm nay</p>
                    </div>
                    <div class="card-body p-4 p-md-5 pt-0">
                        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()

                            @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3 fw-bold text-center" })

                            <div class="mb-3">
                                <label class="small fw-bold text-muted mb-1">Họ và Tên</label>
                                @Html.TextBoxFor(m => m.FullName, new { @class = "form-control py-2" })
                                @Html.ValidationMessageFor(m => m.FullName, "", new { @class = "text-danger small fw-bold" })
                            </div>

                            <div class="mb-3">
                                <label class="small fw-bold text-muted mb-1">Tên đăng nhập (Username)</label>
                                @Html.TextBoxFor(m => m.Username, new { @class = "form-control py-2" })
                                @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger small fw-bold" })
                            </div>

                            <div class="mb-3">
                                <label class="small fw-bold text-muted mb-1">Email</label>
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control py-2", placeholder = "VD: 24521068@gm.uit.edu.vn" })
                                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger small fw-bold" })
                            </div>

                            <div class="mb-3">
                                <label class="small fw-bold text-muted mb-1">Mật khẩu</label>
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control py-2" })
                                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small fw-bold" })
                            </div>

                            <div class="mb-4">
                                <label class="small fw-bold text-muted mb-1">Xác nhận mật khẩu</label>
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control py-2" })
                                @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small fw-bold" })
                            </div>

                            <button type="submit" class="btn w-100 py-3 fw-bold text-white rounded-pill pulse-button mb-3" style="background-color: var(--accent-orange);">
                                ĐĂNG KÝ TÀI KHOẢN
                            </button>

                            <p class="text-center text-muted small mb-0">Đã có tài khoản? <a href="@Url.Action("Login", "Account")" class="fw-bold text-decoration-none" style="color: var(--primary-blue);">Quay lại trang đăng nhập</a></p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>