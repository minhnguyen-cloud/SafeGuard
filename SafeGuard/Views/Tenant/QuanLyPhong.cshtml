@{
    ViewBag.Title = "Quản Lý Dãy Trọ";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid p-0">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="background:none;border:none;float:right;font-size:1.5rem;">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Lỗi!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="background:none;border:none;float:right;font-size:1.5rem;">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4 anim-fade-up">
        <h5 class="fw-bold text-dark mb-0">Danh sách các dãy trọ</h5>

        <button id="btnOpenModal" type="button" class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#addBlockModal" data-toggle="modal" data-target="#addBlockModal">
            <i class="fa-solid fa-plus me-2"></i>Thêm Dãy Mới
        </button>
    </div>

    <div class="row g-4">
        @if (ViewBag.Blocks != null)
        {
            int delay = 1;
            foreach (var block in ViewBag.Blocks)
            {
                <div class="col-md-4 anim-fade-up delay-@delay">
                    <div class="custom-card p-4 position-relative overflow-hidden h-100">
                        <div class="position-absolute top-0 start-0 w-100" style="height: 4px; background-color: var(--primary-blue);"></div>

                        <div class="d-flex justify-content-between align-items-start mb-3 mt-2">
                            <h5 class="fw-bold mb-0 text-dark">@block["BlockName"].AsString()</h5>
                            <span class="badge bg-success bg-opacity-10 text-success border border-success">Hoạt động</span>
                        </div>
                        <p class="text-muted small mb-4"><i class="fa-solid fa-location-dot me-2"></i>@block["Address"].AsString()</p>

                        <div class="row text-center mb-3">
                            <div class="col-6 border-end">
                                <h4 class="fw-bold mb-0 text-dark">@block["TotalRooms"].AsInt()</h4>
                                <small class="text-muted">Tổng Phòng</small>
                            </div>
                            <div class="col-6">
                                <h4 class="fw-bold mb-0 text-primary">@block["ActiveRooms"].AsInt()</h4>
                                <small class="text-muted">Đang Thuê</small>
                            </div>
                        </div>
                        <button class="btn btn-outline-secondary w-100 btn-sm mt-auto">Xem chi tiết</button>
                    </div>
                </div>
                delay++;
            }
        }
    </div>
</div>

<div class="modal fade" id="addBlockModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark">Thêm Dãy Trọ Mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                <button type="button" class="close d-none" data-dismiss="modal" aria-label="Close" style="background:none;border:none;font-size:1.5rem;">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form method="post" action="@Url.Action("ThemDayMoi", "Admin")">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Tên Dãy Trọ</label>
                        <input type="text" name="blockName" class="form-control" placeholder="Ví dụ: Dãy C (Khu Đông)" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Địa chỉ</label>
                        <input type="text" name="address" class="form-control" placeholder="Nhập địa chỉ cụ thể..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Số lượng phòng (Tối đa 5)</label>
                        <input type="number" name="numberOfRooms" class="form-control" value="5" min="1" max="5" required>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal" data-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary fw-bold px-4">Lưu Dãy Mới</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Lắng nghe sự kiện click vào nút Thêm Dãy Mới
            $("#btnOpenModal").click(function () {
                // Ép hiển thị Modal
                $("#addBlockModal").modal('show');
            });

            // Xử lý nút tắt Modal nếu dùng Bootstrap bản cũ
            $(".btn-close, .close, [data-dismiss='modal']").click(function(){
                $("#addBlockModal").modal('hide');
            });
        });
    </script>
}