@{
    ViewBag.Title = "Quản Lý Phòng Của Tôi";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .anim-fade-up {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .premium-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
    }

    .card-top-accent {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 5px;
        background: linear-gradient(90deg, #0d6efd, #0dcaf0);
    }

    .btn-gradient {
        background: linear-gradient(135deg, #0d6efd, #0053ce);
        color: white;
        border: none;
        transition: all 0.3s;
    }

        .btn-gradient:hover {
            transform: scale(1.05);
            color: white;
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.3);
        }

    .invite-input {
        letter-spacing: 2px;
        border-radius: 12px;
        border: 2px dashed #dee2e6;
        text-transform: uppercase;
    }

    .contact-admin-note {
        background-color: #fff3cd;
        color: #856404;
        border-radius: 10px;
        padding: 10px;
        font-size: 0.85rem;
        border: 1px solid #ffeeba;
    }
</style>

<div class="container-fluid py-4 p-0">
    <div class="anim-fade-up">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px;">
                <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 12px;">
                <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between align-items-center mb-5 anim-fade-up">
        <div>
            <h4 class="fw-bold text-dark mb-1">Danh sách phòng trọ</h4>
            <p class="text-muted small mb-0">Xem trạng thái căn phòng bạn đang tham gia</p>
        </div>

        <button type="button" class="btn btn-gradient fw-bold px-4 py-2 rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#joinRoomModal">
            <i class="fa-solid fa-key me-2"></i>Tham gia phòng trọ
        </button>
    </div>

    <div class="row g-4">
        @if (Session["AssignedRoom"] != null)
        {
            <div class="col-md-6 col-xl-4 anim-fade-up">
                <div class="premium-card p-4 h-100">
                    <div class="card-top-accent"></div>
                    <div class="d-flex justify-content-between mb-3">
                        <h5 class="fw-bold mb-0 text-dark">Phòng @Session["AssignedRoom"]</h5>
                        <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-1">Đã kết nối</span>
                    </div>
                    <p class="text-muted small mb-4"><i class="fa-solid fa-circle-check text-primary me-2"></i>Hệ thống SafeGuard đang giám sát an toàn cho bạn.</p>
                    <a href="@Url.Action("LichSuCanhBao", "Tenant")" class="btn btn-outline-primary w-100 fw-bold rounded-3">Xem lịch sử cảm biến</a>
                </div>
            </div>
        }
        else
        {
            <div class="col-12 text-center py-5 anim-fade-up">
                <i class="fa-solid fa-house-circle-xmark text-muted opacity-25" style="font-size: 6rem;"></i>
                <h5 class="fw-bold text-dark mt-4">Chưa có dữ liệu phòng trọ</h5>
                <p class="text-muted">Bạn chưa liên kết với phòng nào. Hãy nhập mã kích hoạt để bắt đầu.</p>

                <div class="d-inline-block mt-2 contact-admin-note">
                    <i class="fa-solid fa-info-circle me-1"></i>
                    <strong>Ghi chú:</strong> Vui lòng liên hệ với <strong>Quản lý (Chủ trọ)</strong> để nhận mã tham gia phòng trọ của bạn.
                </div>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="joinRoomModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0 px-4 pt-4">
                <h5 class="modal-title fw-bold"><i class="fa-solid fa-right-to-bracket text-primary me-2"></i>Tham gia phòng trọ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="formXacNhanMa">
                <div class="modal-body p-4">
                    <div class="alert alert-info border-0 small mb-4" style="background-color: #e3f2fd; color: #0d47a1; border-radius: 12px;">
                        Nhập chính xác mã kích hoạt để hệ thống tự động nhận diện phòng của bạn.
                    </div>

                    <div class="mb-4 text-center">
                        <label class="form-label fw-bold small text-muted text-uppercase mb-2">Mã Kích Hoạt (Invite Code)</label>
                        <input type="text" id="txtInviteCode" name="inviteCode" class="form-control form-control-lg text-center fw-bold text-primary invite-input shadow-sm"
                               placeholder="VD: A-101-X4Y2" required autofocus maxlength="50">
                    </div>

                    <div class="contact-admin-note text-center">
                        <i class="fa-solid fa-headset me-1"></i> Nếu chưa có mã, hãy liên hệ chủ trọ để được cấp.
                    </div>
                </div>

                <div class="modal-footer p-4 border-top-0 pt-0">
                    <button type="button" id="btnXacNhan" class="btn btn-primary w-100 py-3 fw-bold shadow-sm" style="border-radius: 12px;">
                        KÍCH HOẠT PHÒNG TRỌ
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            let isSubmitting = false;

            function normalizeInviteCode(code) {
                return (code || '').trim().toUpperCase();
            }

            function setSubmitState(disabled) {
                const btn = $('#btnXacNhan');
                btn.prop('disabled', disabled);
                btn.html(disabled
                    ? '<span class="spinner-border spinner-border-sm me-2"></span>ĐANG KIỂM TRA...'
                    : 'KÍCH HOẠT PHÒNG TRỌ');
            }

            function submitInviteCode() {
                if (isSubmitting) return;

                let code = normalizeInviteCode($('#txtInviteCode').val());
                $('#txtInviteCode').val(code);

                if (!code) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Thiếu thông tin',
                        text: 'Vui lòng nhập mã kích hoạt!',
                        confirmButtonColor: '#3085d6'
                    });
                    return;
                }

                if (code.length < 5) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Mã chưa hợp lệ',
                        text: 'Mã kích hoạt có vẻ quá ngắn. Vui lòng kiểm tra lại.',
                        confirmButtonColor: '#3085d6'
                    });
                    return;
                }

                isSubmitting = true;
                setSubmitState(true);

                Swal.fire({
                    title: 'Đang kiểm tra mã...',
                    allowOutsideClick: false,
                    allowEscapeKey: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                $.ajax({
                    url: '@Url.Action("XacNhanMaPhong", "Tenant")',
                    type: 'POST',
                    data: { inviteCode: code },
                    success: function (res) {
                        isSubmitting = false;
                        setSubmitState(false);

                        if (res.success) {
                            $('#joinRoomModal').modal('hide');
                            Swal.fire({
                                icon: 'success',
                                title: 'Thành công!',
                                text: res.message,
                                confirmButtonColor: '#28a745'
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Không hợp lệ',
                                text: res.message,
                                confirmButtonColor: '#d33'
                            });
                        }
                    },
                    error: function () {
                        isSubmitting = false;
                        setSubmitState(false);

                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi mạng',
                            text: 'Không thể kết nối đến máy chủ. Vui lòng thử lại!',
                            confirmButtonColor: '#d33'
                        });
                    }
                });
            }

            $('#btnXacNhan').click(function () {
                submitInviteCode();
            });

            $('#txtInviteCode').keypress(function (e) {
                if (e.which === 13) {
                    e.preventDefault();
                    submitInviteCode();
                }
            });

            $('#joinRoomModal').on('hidden.bs.modal', function () {
                isSubmitting = false;
                setSubmitState(false);
                $('#formXacNhanMa')[0].reset();
            });
        });
    </script>
}