@model SafeGuard.Controllers.TenantDashboardVM
@{
    ViewBag.Title = "Tổng Quan Phòng Của Tôi";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    // Xử lý logic đổi màu cho phần nhiệt độ
    string tempClass = Model.IsAlert ? "text-danger" : "text-primary";
    string tempBorderColor = Model.IsAlert ? "rgba(220, 53, 69, 0.2)" : "rgba(13, 110, 253, 0.1)";
    string tempHoverBorder = Model.IsAlert ? "rgba(220, 53, 69, 0.4)" : "rgba(13, 110, 253, 0.3)";
    string tempShadow = Model.IsAlert ? "rgba(220, 53, 69, 0.15)" : "rgba(13, 110, 253, 0.15)";
    string bgTheme = Model.IsAlert ? "danger" : "primary";

    // Xử lý banner an toàn
    string bannerBg = Model.IsAlert ? "linear-gradient(135deg, #f8d7da 0%, #f1aeb5 100%)" : "linear-gradient(135deg, #d1e7dd 0%, #a3cfbb 100%)";
    string bannerBorder = Model.IsAlert ? "#ea868f" : "#86b7fe";
    string bannerText = Model.IsAlert ? "text-danger" : "text-success";
    string bannerIcon = Model.IsAlert ? "fa-fire" : "fa-shield-halved";

    // Ghép chuỗi tên phòng
    string roomDisplay = Model.RoomName != "Chưa có" ? $"{Model.RoomName} - {Model.BlockName}" : "Chưa có";
}

<style>
    /* Hiệu ứng xuất hiện mượt mà */
    .anim-fade-up {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Thiết kế thẻ Card hiện đại (Đồng bộ toàn hệ thống) */
    .premium-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
    }

        .premium-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.08);
        }

    .card-top-accent {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 4px;
    }

    .card-bg-icon {
        position: absolute;
        right: -15px;
        bottom: -15px;
        font-size: 8rem;
        z-index: 0;
        transform: rotate(-15deg);
        transition: all 0.3s;
    }

    .premium-card:hover .card-bg-icon {
        transform: rotate(0deg) scale(1.1);
    }

    /* Vòng tròn nhiệt độ Smart Home - Tự động đổi màu viền khi nóng */
    .temp-circle {
        width: 160px;
        height: 160px;
        border-radius: 50%;
        background: #fff;
        border: 8px solid @tempBorderColor;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 4px 10px rgba(0,0,0,0.05), 0 10px 20px @tempShadow;
        transition: all 0.4s ease;
    }

    .premium-card:hover .temp-circle {
        border-color: @tempHoverBorder;
        transform: scale(1.05);
    }

    /* Banner an toàn */
    .safety-banner {
        background: @bannerBg;
        border: 1px solid @bannerBorder;
    }
</style>

<div class="container-fluid py-4 p-0">

    <div id="tenantSafetyBanner" class="alert safety-banner border-0 shadow-sm rounded-4 anim-fade-up d-flex align-items-center mb-4 p-4 position-relative overflow-hidden">
        <div class="bg-white rounded-circle p-3 d-flex align-items-center justify-content-center position-relative z-1 me-4 shadow-sm" style="width: 65px; height: 65px;">
            <i id="tenantSafetyIcon" class="fa-solid @bannerIcon @bannerText fs-2 fa-beat-fade" style="--fa-animation-duration: 2s;"></i>
        </div>
        <div class="position-relative z-1">
            <h5 id="tenantSafetyTitle" class="fw-bold @bannerText mb-1 letter-spacing-1">@(Model.IsAlert ? "CẢNH BÁO AN TOÀN!" : "TRẠNG THÁI AN TOÀN!")</h5>
            <span id="tenantSafetyMessage" class="text-dark">@Model.StatusMessage</span>
        </div>
        <i class="fa-solid fa-leaf position-absolute @bannerText opacity-25" style="font-size: 8rem; right: -20px; top: -30px; transform: rotate(15deg);"></i>
    </div>
    <div class="premium-card p-4 mb-4 anim-fade-up">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div>
                <h6 class="fw-bold text-muted mb-2 text-uppercase" style="letter-spacing: 1px;">
                    Mô phỏng dữ liệu kiểm thử
                </h6>
                <p class="text-muted mb-0 small">
                    Tạo nhanh chuỗi dữ liệu mẫu để kiểm tra dashboard, cảnh báo nhiệt độ và lịch sử hệ thống.
                </p>
            </div>

            <div class="d-flex flex-wrap gap-2">
                @using (Html.BeginForm("CreateDemoData", "Tenant", FormMethod.Post, new { id = "createDemoForm", @class = "m-0" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" id="btnCreateDemo" class="btn btn-primary fw-bold rounded-pill px-4 shadow-sm">
                        <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Tạo dữ liệu mẫu
                    </button>
                }

                @using (Html.BeginForm("DeleteDemoData", "Tenant", FormMethod.Post, new { id = "deleteDemoForm", @class = "m-0" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" id="btnDeleteDemo" class="btn btn-outline-danger fw-bold rounded-pill px-4 shadow-sm">
                        <i class="fa-solid fa-trash-can me-2"></i>Xóa dữ liệu mẫu
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-6 anim-fade-up delay-1">
            <div class="premium-card p-4 text-center d-flex flex-column justify-content-center h-100 z-1">
                <div class="card-top-accent bg-@bgTheme"></div>
                <i class="fa-solid fa-temperature-three-quarters card-bg-icon @tempClass opacity-10"></i>

                <h6 class="fw-bold text-muted mb-4 text-uppercase" style="letter-spacing: 1px;">Trạng Thái Nhiệt Độ Phòng</h6>

                <div id="tenantTempCircle" class="temp-circle mx-auto mb-4 position-relative z-1">
                    <h1 id="tenantCurrentTemperature" class="display-3 fw-black @tempClass mb-0">@(Model.HasData ? Model.CurrentTemperature.ToString() : "--")<span class="fs-3 text-muted">°C</span></h1>
                </div>

                <div class="position-relative z-1">
                    <span id="tenantMonitorBadge" class="badge bg-@bgTheme bg-opacity-10 @tempClass border border-@bgTheme rounded-pill px-4 py-2 shadow-sm">
                        <i class="fa-solid fa-satellite-dish fa-fade me-2"></i>Đang giám sát (Real-time)
                    </span>
                </div>
            </div>
        </div>

        <div class="col-md-6 anim-fade-up delay-2">
            <div class="premium-card p-4 h-100 z-1">
                <div class="card-top-accent bg-info"></div>
                <i class="fa-solid fa-server card-bg-icon text-info opacity-10"></i>

                <h6 class="fw-bold text-muted mb-4 text-uppercase" style="letter-spacing: 1px;">Thông Tin Liên Kết Hệ Thống</h6>

                <ul class="list-unstyled mt-3 mb-0 position-relative z-1">
                    <li class="d-flex justify-content-between align-items-center mb-3 bg-light p-3 rounded-3 border-start border-4 border-secondary transition-hover">
                        <span class="text-muted fw-semibold"><i class="fa-solid fa-door-open me-2 text-secondary"></i>Phòng đang thuê:</span>
                        <strong class="text-dark fs-6">@roomDisplay</strong>
                    </li>
                    <li class="d-flex justify-content-between align-items-center mb-3 bg-light p-3 rounded-3 border-start border-4 border-success transition-hover">
                        <span class="text-muted fw-semibold"><i class="fa-solid fa-wifi me-2 text-success"></i>Tình trạng kết nối:</span>
                        <strong id="tenantConnectionStatus" class="text-success fs-6"><i class="fa-solid fa-check me-1"></i>Đã đồng bộ</strong>
                    </li>
                    <li class="d-flex justify-content-between align-items-center bg-light p-3 rounded-3 border-start border-4 border-info transition-hover">
                        <span class="text-muted fw-semibold"><i class="fa-solid fa-clock-rotate-left me-2 text-info"></i>Cập nhật lần cuối:</span>
                        <strong id="tenantLastUpdated" class="text-dark fs-6">Vừa xong</strong>
                    </li>
                </ul>

                <a href="@Url.Action("QuanLyPhong", "Tenant")" class="btn btn-outline-primary w-100 mt-4 fw-bold rounded-pill position-relative z-1 shadow-sm">
                    Xem chi tiết phòng <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
        @section Scripts {
            <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
            <script>
        $(document).ready(function () {

            function setButtonState($btn, loading, loadingText, normalHtml) {
                if (loading) {
                    $btn.prop('disabled', true);
                    $btn.data('original-html', normalHtml);
                    $btn.html('<span class="spinner-border spinner-border-sm me-2"></span>' + loadingText);
                } else {
                    $btn.prop('disabled', false);
                    $btn.html($btn.data('original-html') || normalHtml);
                }
            }

            $('#createDemoForm').on('submit', function (e) {
                e.preventDefault();

                const $btn = $('#btnCreateDemo');
                const normalHtml = $btn.html();

                setButtonState($btn, true, 'Đang tạo...', normalHtml);

                $.ajax({
                    url: '@Url.Action("CreateDemoData", "Tenant")',
                    type: 'POST',
                    data: $(this).serialize(),
                    success: function (res) {
                        setButtonState($btn, false, '', normalHtml);

                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Tạo dữ liệu thành công',
                                html: `
                                    <div class="text-start">
                                        <p class="mb-2"><strong>Phòng:</strong> ${res.roomId}</p>
                                        <p class="mb-0"><strong>Số mốc dữ liệu:</strong> ${res.points}</p>
                                    </div>
                                `,
                                confirmButtonText: 'Làm mới dashboard'
                            }).then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Không thể tạo dữ liệu',
                                text: res.message || 'Đã xảy ra lỗi không xác định.'
                            });
                        }
                    },
                    error: function () {
                        setButtonState($btn, false, '', normalHtml);

                        Swal.fire({
                            icon: 'error',
                            title: 'Lỗi kết nối',
                            text: 'Không thể kết nối đến máy chủ. Vui lòng thử lại.'
                        });
                    }
                });
            });

            $('#deleteDemoForm').on('submit', function (e) {
                e.preventDefault();

                Swal.fire({
                    title: 'Xóa dữ liệu mẫu?',
                    text: 'Thao tác này sẽ xóa toàn bộ dữ liệu demo của bạn và có thể gỡ phòng demo nếu hệ thống đã tự gán.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Xóa dữ liệu',
                    cancelButtonText: 'Hủy',
                    confirmButtonColor: '#dc3545'
                }).then((result) => {
                    if (!result.isConfirmed) return;

                    const $btn = $('#btnDeleteDemo');
                    const normalHtml = $btn.html();

                    setButtonState($btn, true, 'Đang xóa...', normalHtml);

                    $.ajax({
                        url: '@Url.Action("DeleteDemoData", "Tenant")',
                        type: 'POST',
                        data: $('#deleteDemoForm').serialize(),
                        success: function (res) {
                            setButtonState($btn, false, '', normalHtml);

                            if (res.success) {
                                if (window.clearRealtimeBannerIfRecovered) {
                                    window.clearRealtimeBannerIfRecovered({ alertLevel: 'NORMAL' });
                                }

                                Swal.fire({
                                    icon: 'success',
                                    title: 'Xóa thành công',
                                    text: res.message
                                }).then(() => {
                                    location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Không thể xóa dữ liệu',
                                    text: res.message || 'Đã xảy ra lỗi không xác định.'
                                });
                            }
                        },
                        error: function () {
                            setButtonState($btn, false, '', normalHtml);

                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi kết nối',
                                text: 'Không thể kết nối đến máy chủ. Vui lòng thử lại.'
                            });
                        }
                    });
                });
            });

        });

        const tenantAssignedRoom = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Session["AssignedRoom"]?.ToString() ?? ""));

        function getTenantRealtimeField(data) {
            for (let i = 1; i < arguments.length; i++) {
                const key = arguments[i];
                if (data[key] !== undefined && data[key] !== null) {
                    return data[key];
                }
            }

            return '';
        }

        function isTenantRoomEvent(data) {
            const roomId = getTenantRealtimeField(data, 'roomId', 'RoomId');
            return !tenantAssignedRoom || !roomId || roomId.toUpperCase() === tenantAssignedRoom.toUpperCase();
        }

        function formatTenantTime(value) {
            if (!value) {
                return 'Vừa xong';
            }

            const numericValue = Number(value);
            const date = !Number.isNaN(numericValue)
                ? new Date((numericValue < 1000000000000 ? numericValue * 1000 : numericValue))
                : new Date(value);

            if (Number.isNaN(date.getTime())) {
                return 'Vừa xong';
            }

            return date.toLocaleTimeString('vi-VN', {
                hour: '2-digit',
                minute: '2-digit',
                hour12: false
            });
        }

        function updateTenantDashboardRealtime(data) {
            if (!isTenantRoomEvent(data)) return;

            const temperature = getTenantRealtimeField(data, 'temperature', 'Temperature');
            const alertLevel = (getTenantRealtimeField(data, 'alertLevel', 'AlertLevel') || 'NORMAL').toUpperCase();
            const deviceStatus = (getTenantRealtimeField(data, 'deviceStatus', 'DeviceStatus') || 'online').toLowerCase();
            const timestamp = getTenantRealtimeField(data, 'timestamp', 'Timestamp', 'triggeredAt', 'TriggeredAt');
            const isAlert = alertLevel === 'FIRE' || alertLevel === 'DANGER' || alertLevel === 'WARNING' || Number(temperature || 0) >= 38;
            const isDanger = alertLevel === 'FIRE' || alertLevel === 'DANGER' || Number(temperature || 0) >= 45;

            if (temperature !== '') {
                $('#tenantCurrentTemperature')
                    .removeClass('text-primary text-danger')
                    .addClass(isAlert ? 'text-danger' : 'text-primary')
                    .html(temperature + '<span class="fs-3 text-muted">°C</span>');
            }

            $('#tenantSafetyBanner')
                .removeClass('alert-success alert-danger')
                .css({
                    background: isAlert ? 'linear-gradient(135deg, #f8d7da 0%, #f1aeb5 100%)' : 'linear-gradient(135deg, #d1e7dd 0%, #a3cfbb 100%)',
                    borderColor: isAlert ? '#ea868f' : '#86b7fe'
                });

            $('#tenantSafetyIcon')
                .removeClass('fa-shield-halved fa-fire text-success text-danger text-primary')
                .addClass(isAlert ? 'fa-fire text-danger' : 'fa-shield-halved text-success');

            $('#tenantSafetyTitle')
                .removeClass('text-success text-danger text-primary')
                .addClass(isAlert ? 'text-danger' : 'text-success')
                .text(isDanger ? 'CẢNH BÁO NGUY HIỂM!' : (isAlert ? 'CẢNH BÁO AN TOÀN!' : 'TRẠNG THÁI AN TOÀN!'));

            $('#tenantSafetyMessage').text(
                data.message ||
                (isDanger ? 'Nhiệt độ phòng đang ở mức nguy hiểm. Vui lòng kiểm tra thiết bị điện ngay khi an toàn.'
                    : isAlert ? 'Nhiệt độ phòng đang cao hơn bình thường. Hãy chú ý theo dõi.'
                    : 'Hệ thống cảm biến nhiệt độ tại phòng bạn đang hoạt động bình thường và ổn định.')
            );

            $('#tenantMonitorBadge')
                .removeClass('bg-primary bg-danger text-primary text-danger border-primary border-danger')
                .addClass(isAlert ? 'bg-danger text-danger border-danger' : 'bg-primary text-primary border-primary');

            $('#tenantConnectionStatus')
                .removeClass('text-success text-muted')
                .addClass(deviceStatus === 'online' ? 'text-success' : 'text-muted')
                .html(deviceStatus === 'online'
                    ? '<i class="fa-solid fa-check me-1"></i>Đã đồng bộ'
                    : '<i class="fa-solid fa-circle-minus me-1"></i>Mất kết nối');

            $('#tenantLastUpdated').text(formatTenantTime(timestamp));
        }

        window.addEventListener('safeguard:realtime', function (e) {
            const data = e.detail || {};

            if (data.type === 'sensor_update' || data.type === 'alert_triggered' || data.type === 'room_status_changed') {
                updateTenantDashboardRealtime(data);
            }
        });
            </script>
        }
    </div>
</div>
