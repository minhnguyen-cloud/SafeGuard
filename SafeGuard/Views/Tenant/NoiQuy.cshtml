@{
    ViewBag.Title = "Nội Quy PCCC";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    /* Cấu hình nền và hiệu ứng chung */
    .pccc-bg {
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    .anim-fade-up {
        animation: fadeInUp 0.8s ease-out forwards;
        opacity: 0;
    }

    .delay-1 {
        animation-delay: 0.2s;
    }

    .delay-2 {
        animation-delay: 0.4s;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Thẻ Nội Quy Cao Cấp */
    .pccc-card {
        background: #ffffff;
        border-radius: 16px;
        border-left: 6px solid #dc3545;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

        .pccc-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(220, 53, 69, 0.05), transparent);
            transition: left 0.5s;
        }

        .pccc-card:hover {
            transform: translateY(-5px) scale(1.01);
            box-shadow: 0 10px 20px rgba(220, 53, 69, 0.1);
            border-left: 6px solid #b02a37;
        }

            .pccc-card:hover::before {
                left: 100%;
            }

    .icon-wrapper {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        font-size: 1.2rem;
    }

    /* Khối Cứu Hỏa chính trong cột col-lg-8 */
    .emergency-box-main {
        background: linear-gradient(135deg, #ff416c, #ff4b2b);
        border-radius: 16px;
        animation: pulse-red-main 2s infinite;
        border: 2px solid rgba(255,255,255,0.2);
    }

    @@keyframes pulse-red-main {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255, 75, 43, 0.5);
        }

        70% {
            transform: scale(1.02);
            box-shadow: 0 0 0 10px rgba(255, 75, 43, 0);
        }

        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(255, 75, 43, 0);
        }
    }

    /* 1. NÚT NỔI HOTLINE GÓC TRÁI (114) */
    .floating-hotline-114 {
        position: fixed;
        bottom: 30px;
        left: 30px;
        background: linear-gradient(135deg, #dc3545, #b02a37);
        color: white;
        padding: 12px 25px;
        border-radius: 50px;
        font-size: 1.2rem;
        font-weight: 900;
        box-shadow: 0 10px 25px rgba(220, 53, 69, 0.5);
        z-index: 9999;
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        transition: all 0.3s;
    }

        .floating-hotline-114:hover {
            color: white;
            transform: scale(1.1) !important;
            text-decoration: none;
        }

        .floating-hotline-114 i {
            font-size: 1.4rem;
            animation: shake 1s infinite;
        }

    @@keyframes shake {
        0% {
            transform: rotate(0deg);
        }

        25% {
            transform: rotate(-15deg);
        }

        50% {
            transform: rotate(15deg);
        }

        75% {
            transform: rotate(-15deg);
        }

        100% {
            transform: rotate(0deg);
        }
    }

    /* 2. CẤU TRÚC NÚT NỔI TRÒN VÀ POPUP BQL */
    .bql-fab-wrapper {
        position: fixed;
        bottom: 100px; /* Nằm ngay trên nút 114 */
        left: 30px;
        z-index: 9998; /* Thấp hơn nút 114 một chút */
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    /* Nút tròn nổi BQL */
    .bql-fab {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        background-color: #0d6efd; /* Màu xanh BQL */
        color: white;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        animation: pulse-blue-fab 2s infinite;
    }

        .bql-fab:hover {
            background-color: #0a58ca;
            transform: scale(1.1);
        }

        .bql-fab.active {
            background-color: #6c757d; /* Đổi màu khi đang mở */
            transform: rotate(45deg); /* Xoay icon để làm nút X đóng */
        }

    @@keyframes pulse-blue-fab {
        0% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.6);
        }

        70% {
            transform: scale(1.05);
            box-shadow: 0 0 0 12px rgba(13, 110, 253, 0);
        }

        100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(13, 110, 253, 0);
        }
    }

    /* Popup thông tin BQL */
    .bql-popup {
        display: none; /* Mặc định ẩn */
        width: 280px;
        background-color: white;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        margin-top: -310px; /* Đẩy popup lên trên nút nổi */
        transform: translateY(10px);
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(0,0,0,0.05);
    }

        .bql-popup.show {
            display: block;
            transform: translateY(0);
            opacity: 1;
        }

    .bql-popup-header {
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding-bottom: 15px;
        margin-bottom: 15px;
    }

    /* Hiệu ứng lướt chuột cho box số điện thoại BQL */
    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            background-color: #e9ecef !important;
            transform: translateX(5px);
        }
</style>

<div class="container-fluid pccc-bg py-5">
    <div class="row justify-content-center">
        <div class="col-xl-10">

            <div class="text-center mb-5 anim-fade-up">
                <h1 class="fw-bold text-danger text-uppercase" style="letter-spacing: 1px;">
                    <i class="fa-solid fa-shield-cat me-2"></i>
                    Nội Quy An Toàn SafeGuard
                </h1>
                <p class="text-muted fs-5">Tuân thủ quy định PCCC là bảo vệ mạng sống của chính bạn</p>
                <div class="mx-auto mt-3" style="height: 4px; width: 80px; background: linear-gradient(90deg, #dc3545, #ff4b2b); border-radius: 2px;"></div>
            </div>

            <div class="row g-4 justify-content-center">
                <div class="col-lg-10">
                    <div class="anim-fade-up delay-1">
                        <div class="pccc-card p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                            <div class="icon-wrapper flex-shrink-0"><i class="fa-solid fa-user-shield"></i></div>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">ĐIỀU 1: TRÁCH NHIỆM CHUNG</h5>
                                <p class="mb-0 text-secondary">PCCC là nghĩa vụ của mọi cư dân. Mọi người phải có trách nhiệm bảo vệ, không được bịt kín hoặc tháo dỡ thiết bị cảm biến SafeGuard trong phòng.</p>
                            </div>
                        </div>

                        <div class="pccc-card p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                            <div class="icon-wrapper flex-shrink-0"><i class="fa-solid fa-plug-circle-bolt"></i></div>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">ĐIỀU 2: AN TOÀN THIẾT BỊ ĐIỆN</h5>
                                <p class="mb-0 text-secondary">Tắt tất cả thiết bị điện, sạc dự phòng, sạc xe điện khi ra khỏi phòng. Không sử dụng dây dẫn điện bị bong tróc, chắp vá.</p>
                            </div>
                        </div>

                        <div class="pccc-card p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                            <div class="icon-wrapper flex-shrink-0"><i class="fa-solid fa-ban"></i></div>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">ĐIỀU 3: NGHIÊM CẤM LỬA TRẦN</h5>
                                <p class="mb-0 text-secondary">Nghiêm cấm đun nấu bằng bếp gas mini, thắp nhang, đốt vàng mã hoặc hút thuốc tại tầng hầm để xe và hành lang chung.</p>
                            </div>
                        </div>

                        <div class="pccc-card p-4 mb-4 shadow-sm d-flex align-items-start gap-3">
                            <div class="icon-wrapper flex-shrink-0"><i class="fa-solid fa-door-open"></i></div>
                            <div>
                                <h5 class="fw-bold text-dark mb-1">ĐIỀU 4: LỐI THOÁT HIỂM</h5>
                                <p class="mb-0 text-secondary">Không để xe máy, rác thải, giày dép làm cản trở lối đi chung, hành lang và cầu thang thoát hiểm của tòa nhà.</p>
                            </div>
                        </div>
                    </div>

                    <div class="anim-fade-up delay-2 text-white p-5 emergency-box-main shadow-lg text-center mt-5 mb-5">
                        <i class="fa-solid fa-truck-medical fa-4x mb-3 text-white-50"></i>
                        <h4 class="fw-bold mb-1 letter-spacing-1">CỨU HỎA KHẨN CẤP</h4>
                        <h1 class="display-2 fw-black mb-0" style="font-weight: 900; text-shadow: 2px 2px 10px rgba(0,0,0,0.3);">114</h1>
                        <p class="mt-2 mb-4 opacity-75 fs-6">Trực ban Cảnh sát PCCC & CNCH (24/7)</p>
                        <a href="tel:114" class="btn btn-light btn-lg fw-bold rounded-pill px-5 shadow-sm">BẤM GỌI NGAY</a>
                    </div>
                </div>

                <div class="col-lg-4 d-none d-lg-block">
                </div>
            </div>

        </div>
    </div>
</div>

