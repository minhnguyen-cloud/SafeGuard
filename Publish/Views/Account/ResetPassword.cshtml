@model SafeGuard.Models.ResetPasswordViewModel
@{
    ViewBag.Title = "Đặt lại mật khẩu - SafeGuard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5 bg-light" style="min-height: 75vh; display: flex; align-items: center;">
    <div class="container mx-auto" style="max-width: 500px;">
        <div class="card border-0 shadow-lg p-5">
            <h2 class="fw-bold text-center mb-3" style="color: var(--primary-blue);">Mật Khẩu Mới</h2>

            <p class="text-center text-muted mb-4">
                Đang đặt lại mật khẩu cho: <strong class="text-dark">@Model.Email</strong>
            </p>

            @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Email)

                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3 fw-bold" })

                <div class="mb-3">
                    <label class="small fw-bold text-muted mb-1">Mã xác nhận từ Email</label>
                    @Html.TextBoxFor(m => m.Code, new { @class = "form-control py-2", placeholder = "Nhập mã 6 số" })
                    @Html.ValidationMessageFor(m => m.Code, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-3">
                    <label class="small fw-bold text-muted mb-1">Mật khẩu mới</label>
                    @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control py-2", placeholder = "Ít nhất 8 ký tự" })
                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
                </div>

                <div class="mb-4">
                    <label class="small fw-bold text-muted mb-1">Xác nhận lại mật khẩu</label>
                    @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control py-2", placeholder = "Nhập lại mật khẩu mới" })
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                </div>

                <button type="submit" class="btn w-100 py-3 fw-bold text-white rounded-pill" style="background-color: var(--primary-blue);">
                    CẬP NHẬT MẬT KHẨU
                </button>
            }
        </div>
    </div>
</section>