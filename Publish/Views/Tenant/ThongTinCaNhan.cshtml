@model SafeGuard.Controllers.TenantProfileVM
@{
    ViewBag.Title = "Thông Tin Cá Nhân";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var avatarSrc = string.IsNullOrWhiteSpace(Model.AvatarUrl) ? "https://via.placeholder.com/140x140?text=Avatar" : Model.AvatarUrl;
}

<style>
    .avatar-wrapper {
        position: relative;
        width: 140px;
        height: 140px;
        margin: 0 auto;
    }

    .avatar-preview {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        border: 4px solid #fff;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        object-fit: cover;
        transition: all 0.3s ease;
    }

    .avatar-edit-btn {
        position: absolute;
        right: 5px;
        bottom: 5px;
        background-color: #dc3545;
        color: white;
        border-radius: 50%;
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 3px solid #fff;
        cursor: pointer;
        transition: all 0.2s ease;
        box-shadow: 0 4px 10px rgba(220, 53, 69, 0.3);
    }

        .avatar-edit-btn:hover {
            background-color: #b02a37;
            transform: scale(1.1);
        }

    .profile-card {
        background: #fff;
        border-radius: 16px;
        border: none;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        margin-bottom: 25px;
    }

    .card-header-custom {
        background-color: transparent;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding: 20px 25px;
        font-weight: 700;
        color: #333;
    }

    .form-control-custom {
        border-radius: 8px;
        padding: 12px 15px;
        border: 1px solid #dee2e6;
        transition: all 0.3s;
    }

        .form-control-custom:focus {
            border-color: #dc3545;
            box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
        }

        .form-control-custom[readonly] {
            background-color: #f8f9fa;
            cursor: not-allowed;
        }

    .anim-fade-up {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }
</style>

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-lg-4 anim-fade-up">
            <div class="profile-card p-4 text-center">
                <div class="avatar-wrapper mb-4">
                    <img id="avatarImage" src="@avatarSrc" alt="Avatar" class="avatar-preview">

                    <label for="avatarUpload" class="avatar-edit-btn" title="Thay đổi ảnh đại diện">
                        <i class="fa-solid fa-camera"></i>
                    </label>
                    <input type="file" id="avatarUpload" accept=".png, .jpg, .jpeg" style="display: none;">
                </div>

                <h4 class="fw-bold text-dark mb-1">@Model.FullName</h4>
                <p class="text-muted mb-3"><i class="fa-solid fa-user-check me-1 text-success"></i> Khách thuê (Tenant)</p>

                <div class="d-flex justify-content-center gap-2 mb-3 flex-wrap">
                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger px-3 py-2 rounded-pill">
                        <i class="fa-solid fa-house-chimney me-1"></i> @(Model.AssignedRoom != "Chưa có" ? "Phòng " + Model.AssignedRoom : "Chưa có phòng")
                    </span>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary px-3 py-2 rounded-pill">
                        <i class="fa-solid fa-location-dot me-1"></i> @Model.Address
                    </span>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="profile-card anim-fade-up">
                <div class="card-header-custom d-flex align-items-center">
                    <i class="fa-solid fa-address-card text-danger fs-4 me-2"></i> THÔNG TIN CÁ NHÂN
                </div>
                <div class="card-body p-4">
                    <form id="formUpdateProfile">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Tên đăng nhập</label>
                                <input type="text" class="form-control form-control-custom" value="@Model.Username" readonly title="Tên đăng nhập không thể thay đổi">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Họ và tên</label>
                                <input type="text" id="txtFullName" name="fullName" class="form-control form-control-custom" value="@Model.FullName" maxlength="100">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Địa chỉ Email</label>
                                <input type="email" id="txtEmail" name="email" class="form-control form-control-custom" value="@Model.Email" placeholder="Nhập email của bạn" maxlength="150">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Số điện thoại</label>
                                <input type="text" id="txtPhone" name="phone" class="form-control form-control-custom" value="@Model.Phone" maxlength="20">
                            </div>

                            <div class="col-12 mt-4">
                                <h6 class="fw-bold border-bottom pb-2 mb-3">Thông tin hợp đồng (Chỉ đọc)</h6>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Khu trọ</label>
                                <input type="text" class="form-control form-control-custom" value="@Model.BlockName" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">Số phòng</label>
                                <input type="text" class="form-control form-control-custom" value="@(Model.AssignedRoom != "Chưa có" ? "Phòng " + Model.AssignedRoom : "Chưa có")" readonly>
                            </div>
                        </div>

                        <div class="text-end mt-4 pt-3 border-top">
                            <button type="button" id="btnSaveProfile" class="btn btn-danger px-4 rounded-pill fw-bold shadow-sm">
                                <i class="fa-solid fa-floppy-disk me-1"></i> Lưu Thông Tin
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const avatarUpload = document.getElementById('avatarUpload');
            const avatarImage = document.getElementById('avatarImage');
            const btnSaveProfile = document.getElementById('btnSaveProfile');
            let selectedFile = null;
            let isSaving = false;

            function isValidEmail(email) {
                if (!email) return true;
                return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
            }

            function isValidPhone(phone) {
                if (!phone) return true;
                return /^[0-9+\-\s]{8,20}$/.test(phone);
            }

            function setSaveState(disabled) {
                btnSaveProfile.disabled = disabled;
                btnSaveProfile.innerHTML = disabled
                    ? '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...'
                    : '<i class="fa-solid fa-floppy-disk me-1"></i> Lưu Thông Tin';
            }

            avatarUpload.addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (!file) return;

                const allowedTypes = ['image/png', 'image/jpeg', 'image/jpg'];
                const maxSize = 5 * 1024 * 1024;

                if (!allowedTypes.includes(file.type)) {
                    Swal.fire('Lỗi', 'Vui lòng chọn file ảnh .jpg, .jpeg hoặc .png', 'error');
                    avatarUpload.value = '';
                    return;
                }

                if (file.size > maxSize) {
                    Swal.fire('Lỗi', 'Ảnh quá lớn. Vui lòng chọn ảnh nhỏ hơn 5MB.', 'error');
                    avatarUpload.value = '';
                    return;
                }

                selectedFile = file;
                const reader = new FileReader();
                reader.onload = function (ev) {
                    avatarImage.src = ev.target.result;
                };
                reader.readAsDataURL(file);
            });

            btnSaveProfile.addEventListener('click', function () {
                if (isSaving) return;

                var fullName = document.getElementById('txtFullName').value.trim();
                var phone = document.getElementById('txtPhone').value.trim();
                var emailInput = document.getElementById('txtEmail').value.trim();

                if (fullName === '') {
                    Swal.fire('Cảnh báo', 'Họ tên không được để trống', 'warning');
                    return;
                }

                if (fullName.length < 2) {
                    Swal.fire('Cảnh báo', 'Họ tên quá ngắn', 'warning');
                    return;
                }

                if (!isValidEmail(emailInput)) {
                    Swal.fire('Cảnh báo', 'Email không đúng định dạng', 'warning');
                    return;
                }

                if (!isValidPhone(phone)) {
                    Swal.fire('Cảnh báo', 'Số điện thoại không hợp lệ', 'warning');
                    return;
                }

                isSaving = true;
                setSaveState(true);

                var formData = new FormData();
                formData.append('fullName', fullName);
                formData.append('phone', phone);
                formData.append('emailInput', emailInput);

                if (selectedFile) {
                    formData.append('avatarFile', selectedFile);
                }

                $.ajax({
                    url: '@Url.Action("CapNhatThongTin", "Tenant")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (res) {
                        isSaving = false;
                        setSaveState(false);

                        if (res.success) {
                            Swal.fire('Thành công!', res.message, 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    },
                    error: function () {
                        isSaving = false;
                        setSaveState(false);
                        Swal.fire('Lỗi mạng', 'Không thể kết nối đến máy chủ S3', 'error');
                    }
                });
            });
        });
    </script>
}