<style>
    /* ========================================== */
    /* CSS MỚI CHO PHẦN GIỚI THIỆU SẢN PHẨM       */
    /* ========================================== */
    .icon-check-circle {
        width: 25px;
        height: 25px;
        background-color: var(--primary-blue);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
    }

    .intro-text-box {
        animation: slideInLeft 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    }

    .intro-image-box {
        animation: slideInRight 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
    }

    .main-intro-img {
        transition: transform 0.5s ease;
    }

    .intro-image-box:hover .main-intro-img {
        transform: scale(1.03);
    }

    /* Hiệu ứng lơ lửng cho hộp badge */
    .float-badge {
        animation: floatUpDown 3s ease-in-out infinite;
        z-index: 2;
    }

    /* Hiệu ứng trượt khi hover vào dòng text */
    .intro-list li {
        transition: transform 0.3s ease, color 0.3s ease;
    }

        .intro-list li:hover {
            transform: translateX(10px);
            color: var(--primary-blue) !important;
        }

    .btn-intro {
        transition: all 0.3s ease;
    }

        .btn-intro:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.25);
        }

    /* Định nghĩa Keyframes */
    @@keyframes slideInLeft {
        0% {
            opacity: 0;
            transform: translateX(-50px);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes slideInRight {
        0% {
            opacity: 0;
            transform: translateX(50px);
        }

        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes floatUpDown {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-15px);
        }

        100% {
            transform: translateY(0px);
        }
    }
    /* ========================================== */

    /* Hiệu ứng Box Tính năng */
    .feature-card {
        transition: all 0.4s ease;
    }

        .feature-card:hover {
            transform: translateY(-15px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
            background-color: #fff !important;
        }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.4s ease;
    }

    .feature-card:hover .icon-wrapper {
        transform: scale(1.15) rotate(10deg);
    }

    /* Hiệu ứng Bảng so sánh */
    .compare-card {
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .compare-list li {
        padding: 15px 0;
        border-bottom: 1px dashed #e0e0e0;
        font-size: 1.1rem;
    }

        .compare-list li:last-child {
            border-bottom: none;
        }

    .traditional-card:hover {
        transform: scale(1.02);
    }

    .safeguard-card {
        border: 2px solid var(--accent-orange);
        transform: scale(1.03);
        z-index: 2;
    }

        .safeguard-card:hover {
            transform: scale(1.06);
            box-shadow: 0 25px 50px rgba(255, 159, 28, 0.2) !important;
        }

    /* Hiệu ứng Đội ngũ */
    .team-card {
        background: transparent;
        transition: all 0.3s ease;
    }

    .team-img-box img {
        width: 160px;
        height: 160px;
        object-fit: cover;
        border: 5px solid white;
        transition: all 0.4s ease;
    }

    .team-card:hover .team-img-box img {
        transform: scale(1.1);
        border-color: var(--accent-orange);
    }

    .social-links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        background-color: #f1f1f1;
        color: var(--primary-blue);
        border-radius: 50%;
        margin: 0 5px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .social-links a:hover {
            background-color: var(--accent-orange);
            color: white;
            transform: translateY(-5px);
        }

    /* Hiệu ứng Chạy chữ ngang (Marquee) */
    .marquee-wrapper {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .marquee-track {
        display: flex;
        width: max-content;
        animation: scrollLeft 20s linear infinite;
    }

        .marquee-track:hover {
            animation-play-state: paused;
        }

    @@keyframes scrollLeft {
        0% {
            transform: translateX(0);
        }

        100% {
            transform: translateX(-50%);
        }
    }

    /* Hình nền cho phần CTA */
    .cta-section {
        background-image: url('https://images.unsplash.com/photo-1542361345-89e58247f2d5?auto=format&fit=crop&q=80&w=1920');
        background-attachment: fixed;
        background-position: center;
        background-size: cover;
    }

    /* Căn chỉnh Mobile */
    @@media (max-width: 768px) {
        .safeguard-card {
            transform: scale(1);
            margin-top: 20px;
        }

            .safeguard-card:hover {
                transform: scale(1.02);
            }
    }
</style>