@{
    ViewBag.Title = "Trang Chủ - SafeGuard";
}

<div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="3000">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/Content/images/Banner1.jpg" class="d-block w-100" alt="Lửa">
            <div class="carousel-caption d-none d-md-block text-center">
                <h1>Hệ Thống Tự Động Giám Sát Và Cảnh Báo <br>Nguy Cơ Cháy <span class="highlight-text">Phòng Trọ & Ký Túc Xá</span></h1>
                <p class="fs-4 mt-3">Phát hiện sớm - Cảnh báo tức thì - Bảo vệ sinh mạng và tài sản</p>
                <a href="@Url.Action("Features", "Home")" class="btn btn-danger btn-lg mt-3 rounded-pill px-5">Xem Tính Năng </a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/Content/images/Banner2.jpg" class="d-block w-100" alt="Cảm biến">
            <div class="carousel-caption d-none d-md-block">
                <h1>Công Nghệ <span class="highlight-text">Cảm Biến Khói & Nhiệt</span> Đám Mây</h1>
                <p class="fs-4 mt-3">Giám sát 24/7 thông qua ứng dụng di động và hệ thống web trung tâm.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/Content/images/Banner3.jpg" class="d-block w-100" alt="Ký túc xá">
            <div class="carousel-caption d-none d-md-block">
                <h1>An Tâm Sinh Sống Tại <span class="highlight-text">Ký Túc Xá Sinh Viên</span></h1>
                <p class="fs-4 mt-3">Tự động liên kết với ban quản lý và trạm cứu hỏa gần nhất khi có sự cố.</p>
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Trước</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Sau</span>
    </button>
</div>

<section class="py-5 position-relative overflow-hidden" style="background-color: #f8faff;" id="about-safeguard">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 intro-text-box">
                <span class="badge px-3 py-2 rounded-pill mb-3 fw-bold shadow-sm" style="background-color: rgba(255, 159, 28, 0.15); color: var(--accent-orange); font-size: 0.9rem;">
                    <i class="fa-solid fa-leaf me-1"></i> Về SafeGuard
                </span>
                <h2 class="display-6 fw-bold mb-4" style="color: var(--primary-blue);">Hệ Sinh Thái Cảnh Báo Cháy <br /><span class="text-danger">Thông Minh 4.0</span></h2>
                <p class="lead text-muted mb-4" style="line-height: 1.8;">SafeGuard không chỉ là chiếc còi báo động đơn thuần. Chúng tôi mang đến một nền tảng giám sát nhiệt độ đột phá, ứng dụng công nghệ <b>IoT và Điện toán đám mây</b>, được thiết kế chuyên biệt để bảo vệ sinh mạng tại các khu trọ và ký túc xá.</p>

                <ul class="list-unstyled mb-5 intro-list">
                    <li class="mb-3 d-flex align-items-center text-secondary fw-medium">
                        <div class="icon-check-circle me-3"><i class="fa-solid fa-check"></i></div>
                        Cảm biến nhạy bén, liên tục cập nhật dữ liệu từng giây.
                    </li>
                    <li class="mb-3 d-flex align-items-center text-secondary fw-medium">
                        <div class="icon-check-circle me-3"><i class="fa-solid fa-check"></i></div>
                        Phân tích tự động để hạn chế tối đa báo động giả.
                    </li>
                    <li class="mb-3 d-flex align-items-center text-secondary fw-medium">
                        <div class="icon-check-circle me-3"><i class="fa-solid fa-check"></i></div>
                        Hoạt động ổn định 24/7 kể cả khi mất wifi.
                    </li>
                </ul>
                <a href="@Url.Action("Features", "Home")" class="btn btn-outline-primary btn-lg rounded-pill px-4 fw-bold btn-intro">
                    Khám phá chi tiết <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>

            <div class="col-lg-6 intro-image-box mt-5 mt-lg-0">
                <div class="position-relative p-2 p-md-4">
                    <img src="https://images.unsplash.com/photo-1558002038-1055907df827?auto=format&fit=crop&q=80&w=800" alt="SafeGuard System" class="img-fluid rounded-5 shadow-lg main-intro-img border border-3 border-white">

                    <div class="position-absolute bg-white p-3 p-md-4 rounded-4 shadow-lg float-badge d-flex align-items-center" style="bottom: 0px; left: 0px; border-left: 5px solid var(--accent-orange);">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3 text-warning">
                            <i class="fa-solid fa-bolt fa-2x"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0 text-dark">&lt; 3 Giây</h4>
                            <span class="text-muted small fw-bold">Thời gian phản hồi</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
